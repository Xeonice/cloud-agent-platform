# dependencies
node_modules/

# build output / compiled artifacts
dist/
.next/
*.tsbuildinfo

# turborepo cache
.turbo/

# prisma generated client (regenerated by `prisma generate` on build)
packages/*/generated/
apps/*/src/generated/

# runtime data (task workspaces + session logs live on a volume, never in git)
workspaces/
*.sqlite
*.sqlite-journal

# env / secrets
.env
.env.*
!.env.example

# os
.DS_Store
