# dependencies
node_modules/

# build output / compiled artifacts
dist/
.next/
coverage/
*.tsbuildinfo

# turborepo cache
.turbo/

# prisma generated client (regenerated by `prisma generate` on build)
packages/*/generated/
apps/*/src/generated/

# runtime data (task workspaces + session logs live on a volume, never in git)
workspaces/
*.sqlite
*.sqlite-journal

# env / secrets
.env
.env.*
!.env.example

# visual-verification artifacts (console-design-pixel-merge Track 8):
# living baselines are re-captured from the design HTML on every run, and
# test-results/ holds per-run actual/diff images — neither is source.
apps/web/e2e/visual/__screenshots__/
apps/web/e2e/test-results/
apps/web/playwright-report/

# os
.DS_Store

# Claude Code runtime lock + worktrees
.claude/scheduled_tasks.lock
.claude/worktrees/

# local tooling / debug artifacts (not part of any change). Repository-owned
# OpenSpec skills must remain visible to Git/lint-staged; all other local
# Codex/Claude skill state remains ignored.
.codex/*
!.codex/skills/
.codex/skills/*
!.codex/skills/openspec-propose/
!.codex/skills/openspec-propose/SKILL.md
!.codex/skills/openspec-apply-change/
!.codex/skills/openspec-apply-change/SKILL.md
.claude/skills/*
!.claude/skills/openspec-apply-change/
!.claude/skills/openspec-apply-change/SKILL.md
!.claude/skills/openspec-archive-change/
!.claude/skills/openspec-archive-change/SKILL.md
!.claude/skills/openspec-explore/
!.claude/skills/openspec-explore/SKILL.md
!.claude/skills/openspec-propose/
!.claude/skills/openspec-propose/SKILL.md
.playwright-mcp/
__pycache__/
*.pyc
