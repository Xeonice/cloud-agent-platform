# dependencies
node_modules/

# build output / compiled artifacts
dist/
.next/
*.tsbuildinfo

# turborepo cache
.turbo/

# prisma generated client (regenerated by `prisma generate` on build)
packages/*/generated/
apps/*/src/generated/

# runtime data (task workspaces + session logs live on a volume, never in git)
workspaces/
*.sqlite
*.sqlite-journal

# env / secrets
.env
.env.*
!.env.example

# visual-verification artifacts (console-design-pixel-merge Track 8):
# living baselines are re-captured from the design HTML on every run, and
# test-results/ holds per-run actual/diff images — neither is source.
apps/web/e2e/visual/__screenshots__/
apps/web/e2e/test-results/
apps/web/playwright-report/

# os
.DS_Store

# Claude Code runtime lock + worktrees
.claude/scheduled_tasks.lock
.claude/worktrees/
