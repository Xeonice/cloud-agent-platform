{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", "**/.env"],
  "globalPassThroughEnv": ["CAP_PUBLIC_SURFACE_EVIDENCE_PATH"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:public-surface": {
      "dependsOn": ["build", "^build"],
      "outputs": [],
      "cache": false
    }
  }
}
