# Copy to `.env` and fill in. `.env` is gitignored; this example is committed.
#
# The apps/api orchestrator and the apps/web console read these.

# --- api: optional legacy single-operator bearer token ---
# Generate a strong random value if you enable the legacy path.
AUTH_TOKEN_LEGACY_ENABLED=true
AUTH_TOKEN=dev-local-operator-token-change-me

# --- api: private-identity layer (add-private-account-identity) ---
# Default-admin bootstrap: with ADMIN_EMAIL set the api idempotently seeds a
# default admin (role=admin, allowed=true, mustChangePassword=true) so a fresh
# deploy is usable. With ADMIN_PASSWORD unset a random password is
# generated and revealed ONCE via POST /auth/admin/reveal (then cleared; the DB
# never stores plaintext). UNSET ADMIN_EMAIL → no admin seeded.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
#
# Email-OTP login over SMTP (ALL FIVE required, else OTP is hidden + fail-closed).
# With these unset, password login still works.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=CAP <no-reply@example.com>
#
# Pre-auth brute-force throttle (IP + submitted email) for the public auth
# endpoints; env-tunable + floored so a bad value can't disable the limiter.
# AUTH_RATE_LIMIT=10
# AUTH_RATE_TTL_SEC=60

# --- api: Postgres (Prisma datasource) ---
# Local dev: a docker postgres mapped to host :5433 (5433 not 5432, to avoid a
# local/homebrew postgres already on 5432; 127.0.0.1 forces IPv4 over ::1).
#   docker run -d --name cap-pg -e POSTGRES_USER=cap -e POSTGRES_PASSWORD=cap \
#     -e POSTGRES_DB=cap -p 5433:5432 postgres:16-alpine
DATABASE_URL=postgresql://cap:cap@127.0.0.1:5433/cap?schema=public

# --- api: server ---
PORT=8080
# docker-compose host port publishing. Defaults bind api/web to all interfaces;
# set *_HOST_BIND=127.0.0.1 for loopback-only. Public DNS/TLS/proxy/firewall and
# OAuth callback/cookie origins are still operator-managed.
API_HOST_BIND=0.0.0.0
API_HOST_PORT=8080
WEB_HOST_BIND=0.0.0.0
WEB_HOST_PORT=3000
# Where workspaces/<id>/session.log lives (a persistent volume in deploy).
WORKSPACES_DIR=./workspaces
# Browser origin allowed for CORS / WS (the web console).
WEB_ORIGIN=http://localhost:3000

# --- local startup sandbox provider ---
# Used by scripts/dev-up.sh / make up:
#   auto          macOS -> BoxLite, Linux -> AIO
#   aio           force AIO full stack
#   boxlite       force BoxLite endpoint-backed stack
#   control-plane api + postgres only, no sandbox provider
CAP_SANDBOX_PROVIDER=auto

# --- api: per-task AIO execution sandbox (connect-in topology, design D) ---
# Pinned derived AIO sandbox image the orchestrator provisions per task as
# cap-aio-<taskId>. MUST be a pinned tag (NEVER :latest) — the derived image is
# built FROM a pinned ghcr.io/agent-infra/sandbox:<tag> with codex + hooks baked
# in (see docker/aio-sandbox.Dockerfile). Defaults to `cap-aio-sandbox:pinned`
# in docker-compose.yml if unset.
AIO_SANDBOX_IMAGE=cap-aio-sandbox:pinned
#
# Optional managed cloud sandbox backend. When this URL is set, the API registers
# both local AIO and cloud HTTP providers behind the single @cap/sandbox facade.
# Provider selection is capability-based; priority wins first, then optional
# CAP_SANDBOX_PREFER_LOCATION breaks ties.
# Capabilities default to terminal.websocket only. Set a comma-separated subset
# or "all" only after the cloud backend implements the matching endpoints.
# CAP_SANDBOX_CLOUD_HTTP_BASE_URL=https://sandbox-control-plane.example.com
# CAP_SANDBOX_CLOUD_HTTP_TOKEN=
# CAP_SANDBOX_CLOUD_HTTP_ID=cloud-http
# CAP_SANDBOX_CLOUD_HTTP_CAPABILITIES=terminal.websocket
# CAP_SANDBOX_CLOUD_HTTP_PRIORITY=50
# CAP_SANDBOX_LOCAL_PRIORITY=10
# CAP_SANDBOX_PREFER_LOCATION=cloud
#
# Optional BoxLite sandbox backend. BoxLite is registered only when this config
# is valid; otherwise AIO remains the default and BoxLite is not advertised.
# Capabilities are explicit and must match the configured backend/image.
# macOS `make up` defaults to the BoxLite path and validates these values before
# reporting the stack as sandbox-ready. CAP does not vendor a BoxLite daemon yet;
# start BoxLite separately or point these at your BoxLite control plane.
# BOXLITE_ENDPOINT=https://boxlite-control-plane.example.com
# BOXLITE_API_TOKEN=
# BOXLITE_IMAGE=cap-boxlite:2026-06-27
# BOXLITE_IMAGE_MAP=codex=cap-boxlite-codex:1,claude-code=cap-boxlite-claude:1
# BOXLITE_PROVIDER_ID=boxlite
# BOXLITE_PROVIDER_PRIORITY=60
# BOXLITE_PROVIDER_LOCATION=cloud
# BOXLITE_WORKSPACE_PATH=/workspace
# BOXLITE_SANDBOX_ID_PREFIX=cap-boxlite-
# BOXLITE_SANDBOX_MODE=workspace-write
# BOXLITE_CLIENT_MODE=rest
# BOXLITE_TIMEOUT_MS=30000
# BOXLITE_TERMINAL_MODE=pty
# BOXLITE_CAPABILITIES=terminal.websocket,terminal.interactive,command.exec,workspace.git.materialize,workspace.git.deliver,workspace.archive.transfer,lifecycle.readopt,lifecycle.readoption
# BOXLITE_HEALTH_PATH=/health
# Set BOXLITE_TERMINAL_MODE=pty and include terminal.websocket,terminal.interactive
# only when the BoxLite backend supports true interactive PTY input/output/resize/reattach.
# BOXLITE_LIVE_TEST=1
#
# NOTE: the legacy runner dial-back environment is intentionally ABSENT.
# Execution migrated to connect-in AIO sandboxes — there is no runner process,
# no dial-back handshake, and no per-task dial-back TASK_TOKEN env.

# --- api: Claude Code runtime auth (optional; add-claude-code-runtime) ---
# Long-lived Claude Code OAuth token that authorizes a `claude-code` task's
# `claude` CLI inside the sandbox (injected as the launch-env CLAUDE_CODE_OAUTH_TOKEN
# by the ClaudeCodeRuntime; no auth file is written). With this UNSET the Claude
# runtime reports not-ready (the create dialog disables it) and a `claude-code`
# create fails closed — the codex path is unaffected.
#
# Mint it on a WORKSTATION (never in-sandbox) where you are signed into Claude:
#   claude setup-token
# Copy the printed token here. Tokens are long-lived (~1yr) with NO auto-refresh;
# re-mint with the same command when tasks start failing with an auth error. A
# single token pools the account's rate limit across all sandboxes AND claude.ai.
# CLAUDE_CODE_OAUTH_TOKEN=

# --- api: guardrail tuning (optional; sensible defaults if unset) ---
# MAX_CONCURRENT_TASKS is the FIRST-BOOT SEED only (configurable-task-slots):
# it sets the slot ceiling until an operator saves "Max concurrent tasks" in
# console Settings. Once saved, the persisted system-level value (SystemSettings
# row) overrides this env on every boot — changing the env after that has no
# effect. With neither set, the ceiling defaults to 5.
# MAX_CONCURRENT_TASKS=5
# Idle reclamation is OPT-IN and OFF BY DEFAULT (task-guardrail-controls): with
# MAX_IDLE_MS unset, a task is never force-failed for idleness unless it was
# created with a per-task `idleTimeoutMs`. Set MAX_IDLE_MS to a positive ms value
# to apply an OPERATOR-LEVEL default idle ceiling to every task that did not opt
# in (a per-task `idleTimeoutMs` always overrides it). Operators stop a wedged
# task deliberately via POST /tasks/:taskId/stop. (Was an implicit 10-minute
# reclaim before; that default is removed.)
# MAX_IDLE_MS=600000
# CIRCUIT_BREAKER_THRESHOLD=3

# --- api: resource sampling (optional) ---
# Background CPU/memory sampling is OFF unless enabled. When on, the sampler reads
# each running sandbox's container stats AND codex's OWN process subtree from inside
# the sandbox (task-codex-process-metrics): the per-task readout shows codex's
# process figure (scope=process) with the container total as background, falling
# back to the container aggregate (scope=container) when the in-sandbox read is
# unavailable. A transient single-tick read miss is carried forward (bounded) so a
# running task never flickers to "not-sampled". Cadence/staleness are tunable.
# METRICS_SAMPLING_ENABLED=true
# METRICS_SAMPLE_CADENCE_MS=5000
# METRICS_SAMPLE_STALE_MS=15000

# --- web: cross-origin api endpoints (NEVER assume same-origin, design D10) ---
# NEXT_PUBLIC_* is what reaches the browser bundle under Next.js.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_AUTH_TOKEN=dev-local-operator-token-change-me
