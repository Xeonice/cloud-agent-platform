# Copy to `.env` and fill in. `.env` is gitignored; this example is committed.
#
# The apps/api orchestrator and the apps/web console read these. The api refuses
# to start without AUTH_TOKEN (single-operator auth, design D12).

# --- api: single-operator bearer token gating ALL REST + WS access ---
# Generate a strong random value in real use (e.g. `openssl rand -hex 32`).
AUTH_TOKEN=dev-local-operator-token-change-me

# --- api: Postgres (Prisma datasource) ---
# Local dev: a docker postgres mapped to host :5433 (5433 not 5432, to avoid a
# local/homebrew postgres already on 5432; 127.0.0.1 forces IPv4 over ::1).
#   docker run -d --name cap-pg -e POSTGRES_USER=cap -e POSTGRES_PASSWORD=cap \
#     -e POSTGRES_DB=cap -p 5433:5432 postgres:16-alpine
DATABASE_URL=postgresql://cap:cap@127.0.0.1:5433/cap?schema=public

# --- api: server ---
PORT=8080
# Where workspaces/<id>/session.log lives (a persistent volume in deploy).
WORKSPACES_DIR=./workspaces
# Browser origin allowed for CORS / WS (the web console).
WEB_ORIGIN=http://localhost:3000

# --- api: per-task AIO execution sandbox (connect-in topology, design D) ---
# Pinned derived AIO sandbox image the orchestrator provisions per task as
# cap-aio-<taskId>. MUST be a pinned tag (NEVER :latest) — the derived image is
# built FROM a pinned ghcr.io/agent-infra/sandbox:<tag> with codex + hooks baked
# in (see docker/aio-sandbox.Dockerfile). Defaults to `cap-aio-sandbox:pinned`
# in docker-compose.yml if unset.
AIO_SANDBOX_IMAGE=cap-aio-sandbox:pinned
#
# NOTE: the legacy runner dial-back environment is intentionally ABSENT.
# Execution migrated to connect-in AIO sandboxes — there is no runner process,
# no dial-back handshake, and no per-task dial-back TASK_TOKEN env.

# --- api: guardrail tuning (optional; sensible defaults if unset) ---
# MAX_CONCURRENT_TASKS=5
# MAX_IDLE_MS=600000
# CIRCUIT_BREAKER_THRESHOLD=3

# --- web: cross-origin api endpoints (NEVER assume same-origin, design D10) ---
# NEXT_PUBLIC_* is what reaches the browser bundle under Next.js.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_AUTH_TOKEN=dev-local-operator-token-change-me
