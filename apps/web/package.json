{
  "name": "@cap/web",
  "version": "0.0.0",
  "private": true,
  "description": "TanStack Start console (web-only; deployed to Vercel via the Nitro vercel preset). Talks to the api over env-configured cross-origin VITE_API_BASE_URL/VITE_WS_URL.",
