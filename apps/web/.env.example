# Cross-origin api endpoints (rebuild-console-tanstack-start D6).
# Only VITE_-prefixed vars are exposed to the client bundle by Vite. The web app
# (Vercel) targets the api (Fly/compose) origin over these — never same-origin.
#
# Every REST call is sent with `credentials: "include"` (see lib/api/real.ts) so
# the httpOnly GitHub-OAuth session cookie rides cross-origin. For that to work
# the api (backend/ops concern, NOT a frontend var) must set
# `Access-Control-Allow-Credentials: true` and an exact
# `Access-Control-Allow-Origin: <this web origin>` (a wildcard `*` is rejected by
# the browser when credentials are included).

# HTTP base URL of the api orchestrator, e.g. https://api.example.fly.dev
VITE_API_BASE_URL=http://localhost:8080

# WebSocket URL of the api orchestrator, e.g. wss://api.example.fly.dev
VITE_WS_URL=ws://localhost:8080

# Legacy single operator bearer token (AUTH_TOKEN) — break-glass / optional.
# Attached to every REST/WS call until the backend migrates to GitHub-OAuth
# session cookies (D1/D6). Distinct from the per-task runner TASK_TOKEN. Leave
# blank once session-cookie auth is live.
VITE_AUTH_TOKEN=

# --- Build target (not a client-exposed var) -------------------------------
# The web build is deployed to Vercel via the Nitro `vercel` preset. The preset
# is selected in-config (`nitro({ preset: "vercel" })` in vite.config.ts); set
# NITRO_PRESET=vercel here only to override that default from the environment
# (e.g. on CI, or to retarget a build without editing source).
# NITRO_PRESET=vercel
