// Prisma schema for the agent-control-platform orchestrator (apps/api).
//
// Track: repo-and-task-management.
// The `TaskStatus` enum mirrors the single-source-of-truth task-status enum in
// `@cap/contracts` (packages/contracts). Prisma cannot import the zod enum
// directly, so the values are kept byte-for-byte identical to the contracts
// `TaskStatus` literals; the lifecycle state machine validates the values it
// reads/writes against the contracts schema at runtime.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Task lifecycle states. MUST stay in sync with the contracts task-status enum.
/// `agent_failed_to_start` is a distinct terminal state, separate from a generic
/// `failed` and from `running`. `queued` is the admission-control holding state
/// used by the concurrency semaphore (guardrails track). `cancelled` is the
/// terminal state for an operator-initiated stop, distinct from both `completed`
/// (clean agent exit) and `failed` (crash / guardrail force-fail).
enum TaskStatus {
  pending
  queued
  running
  awaiting_input
  completed
  failed
  cancelled
  agent_failed_to_start
}

/// A registered repository the operator can launch tasks against.
///
/// The GitHub-import metadata columns (`description`, `defaultBranch`,
/// `branchCount`, `updatedAt`, `githubId`) are all NULLABLE: they are populated
/// only when the repo was imported from GitHub. A plain `gitSource`-only repo
/// created without GitHub import stays valid with these columns null. `githubId`
/// is the originating GitHub repository identity, carried so imports can be
/// de-duplicated. Names mirror the `@cap/contracts` `RepoSchema`.
model Repo {
  id        String   @id @default(uuid())
  /// Human-friendly display name.
  name      String
  /// Git source (clone URL / remote) the runner checks out from.
  gitSource String   @map("git_source")
  createdAt DateTime @default(now()) @map("created_at")

  /// GitHub repo description (import metadata). Null when not imported.
  description   String?   @map("description")
  /// GitHub default branch name (import metadata). Null when not imported.
  defaultBranch String?   @map("default_branch")
  /// GitHub branch count (import metadata). Null when not imported.
  branchCount   Int?      @map("branch_count")
  /// GitHub last-updated timestamp (import metadata). Null when not imported.
  updatedAt     DateTime? @map("updated_at")
  /// Originating GitHub repository identity, used to de-duplicate imports.
  /// Null when not imported from GitHub.
  githubId      String?   @map("github_id")
  /// Whether this imported Repo is the operator's current DEFAULT repo for
  /// task-creation selection. At most one Repo is ever `true`; designating a new
  /// default clears the prior one. Only an imported Repo may carry `true`.
  isDefault     Boolean   @default(false) @map("is_default")

  tasks Task[]

  @@map("repos")
}

/// A single agent task scoped to one `Repo`.
model Task {
  id     String @id @default(uuid())
  /// FK to the owning repository.
  repoId String @map("repo_id")
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  /// The operator-supplied prompt/instruction driving the agent.
  prompt String

  /// Current lifecycle state; defaults to `pending` on creation.
  status TaskStatus @default(pending)

  /// Optional run parameter echoed back from the create body: the git branch the
  /// runner checks out. Inert with respect to the lifecycle; null when omitted.
  branch   String? @map("branch")
  /// Optional run parameter echoed back from the create body: the execution
  /// strategy. Inert with respect to the lifecycle; null when omitted.
  strategy String? @map("strategy")

  /// Optional run parameter: the skill/method ids (e.g. "openspec", "bmad") the
  /// operator chose to preinstall into the task workspace at provision time
  /// (task-preinstall-skills). Inert with respect to the lifecycle; empty when
  /// none were selected. Postgres text[] ŌĆö echoed back on every task read path.
  skills String[] @default([]) @map("skills")

  /// Optional per-task guardrail parameter: the idle ceiling in milliseconds.
  /// Idle reclamation is OPT-IN and OFF by default ŌĆö null means the task is never
  /// force-failed for idleness (unless an operator-level `MAX_IDLE_MS` default is
  /// configured). Consumed at admission to arm the idle watcher AND persisted so
  /// the configured value is readable on every task read path.
  idleTimeoutMs Int? @map("idle_timeout_ms")
  /// Optional per-task guardrail parameter: the wall-clock deadline in
  /// milliseconds from admission. Null means no deadline. Consumed at admission to
  /// arm the deadline watcher AND persisted (previously transient) so the
  /// configured value is readable on every task read path.
  deadlineMs    Int? @map("deadline_ms")

  /// Optional agent-runtime selector echoed back from the create body
  /// (`claude-code` | `codex`). Additive and NULLABLE: existing rows backfill to
  /// NULL and an omitted-on-create value reads back as the default `codex` (the
  /// service applies the default; the column itself stores null when unset).
  /// Persisted as text and kept in sync with the `@cap/contracts` `RuntimeSchema`
  /// values (add-claude-code-runtime).
  runtime String? @map("runtime")

  createdAt DateTime @default(now()) @map("created_at")

  /// Append-only audit events recorded for this task's lifecycle transitions.
  auditEvents AuditEvent[]

  /// The durable, container-independent transcript index for this task (zero or
  /// one). Populated at terminal capture or read-through backfill; survives
  /// container reaping (persist-session-transcripts).
  sessionTranscript SessionTranscript?

  @@index([repoId])
  @@map("tasks")
}

/// An authenticated GitHub operator identity (multi-user-oauth spec).
///
/// Keyed on the immutable GitHub numeric `id` (`githubId`), NOT the mutable
/// `login`, mirroring `@cap/contracts` `SessionUserSchema`. Contracts models
/// `githubId` as `z.number().int()`, so it is stored as `Int` here. `login`,
/// `name`, and `avatarUrl` are mutable profile fields refreshed on each login.
/// `allowed` is the load-bearing fail-closed allowlist gate: only an
/// allowlisted identity is ever surfaced as a session user.
model User {
  id                String   @id @default(uuid())
  /// Stable, immutable GitHub numeric account id; the allowlist + user-record key.
  githubId          Int      @unique @map("github_id")
  /// GitHub `login` (mutable username), refreshed on each login.
  login             String
  /// GitHub display name, captured for console rendering.
  name              String
  /// GitHub avatar reference, captured for console rendering.
  avatarUrl         String   @map("avatar_url")
  /// Whether this identity is presently on the fail-closed allowlist.
  allowed           Boolean
  /// The operator's GitHub OAuth access token, stored server-side (never exposed
  /// to the browser) for later GitHub-import calls (`/user/repos`). Nullable: a
  /// record predating token capture, or a refresh that did not re-capture a
  /// token, leaves it null. Only ever written for an identity that has already
  /// passed the fail-closed allowlist gate.
  githubAccessToken String?  @map("github_access_token")
  createdAt         DateTime @default(now()) @map("created_at")

  sessions        Session[]
  /// Audit events attributed to this GitHub-identity user (nullable on the
  /// event side for system-originated events).
  auditEvents     AuditEvent[]
  /// Per-account console preferences (zero or one).
  accountSettings AccountSettings?
  /// Per-account Codex execution credential (zero or one).
  codexCredential CodexCredential?

  @@map("users")
}

/// An opaque server-side session for an authenticated {@link User}.
///
/// `tokenHash` stores a HASH of the opaque session token, never the raw token,
/// so a database read can never recover a usable credential. Sessions cascade
/// when the owning user is deleted.
model Session {
  id        String   @id @default(uuid())
  /// FK to the owning user.
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// HASH of the opaque session token (never the raw token).
  tokenHash String   @map("token_hash")
  /// Absolute expiry; a session past this is treated as unauthenticated.
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tokenHash])
  @@index([userId])
  @@map("sessions")
}

/// An immutable, append-only audit event (audit-history spec).
///
/// One row is written at the moment of each task lifecycle transition and
/// notable operational outcome. By convention these rows are NEVER mutated or
/// deleted by lifecycle progression: a task's full ordered history stays
/// queryable even after it reaches a terminal state. Every event references a
/// REAL task id via the `taskId` FK and is never orphaned (cascade on task
/// delete). `userId` attributes the event to the GitHub-identity operator under
/// whom the action occurred; it is NULLABLE for system-originated events with no
/// attributed user.
///
/// Shape mirrors `@cap/contracts` `AuditEventSchema`. The contracts `userId`
/// wire field is the GitHub numeric account id (`githubId`); at this storage
/// layer the column is an FK to `users.id` (the user-record key), and the
/// service maps between the two.
model AuditEvent {
  id     String @id @default(uuid())
  /// FK to the owning task; every event references a real task and cascades on
  /// task delete.
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// FK to the attributed GitHub-identity user (the operator the action occurred
  /// under). NULL for system-originated events with no attributed user.
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  /// The lifecycle/audit kind, e.g. `task.created`, `task.running`,
  /// `task.completed`, `task.failed`, `task.cancelled`, `agent_failed_to_start`,
  /// `force_failed`.
  type String

  /// Severity governing the colored audit-dot: `info` | `warning` | `error`.
  level String

  /// Short, human-readable title for the timeline row.
  title String

  /// Human-readable description; for a force-fail it names the cause (deadline /
  /// idle / circuit-break).
  description String

  /// Server-assigned UTC timestamp at which the event was recorded.
  timestamp DateTime @default(now())

  /// Optional HTTP-status-like result code the console renders verbatim
  /// (`201`/`200`/`409`/`422`). Null when the event carries no result code.
  resultCode Int? @map("result_code")

  /// Session linkage: the most recent run identifier where one applies, letting
  /// the console deep-link the event's task to its live session route. Null when
  /// the event has no associated run.
  runId String? @map("run_id")

  @@index([taskId, timestamp])
  @@index([timestamp])
  @@map("audit_events")
}

/// Per-account console preferences (account-settings spec).
///
/// Scoped one-per-user via the UNIQUE `userId`. `allowedAccount` is intentionally
/// NOT stored: it is the read-only allowlisted account display identity sourced
/// from the OAuth identity at read time. `defaultRepoId` references an imported
/// `Repo` by id and is NULLABLE; it is validated in the service layer (the
/// account must have imported that repo) rather than enforced as a DB FK.
/// Mirrors `@cap/contracts` `AccountSettingsSchema` (writable fields only).
model AccountSettings {
  id     String @id @default(uuid())
  /// FK to the owning user; UNIQUE so there is at most one settings row per
  /// account.
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Selected default repository (a `Repo` id), or null when unset. Validated in
  /// the service layer, not enforced as a DB foreign key.
  defaultRepoId String? @map("default_repo_id")

  /// History/audit retention window in days (contracts constrains to 7/30/90/180).
  retention Int

  /// Destructive-action gate toggle ("ńĀ┤ÕØÅµĆ¦ÕåÖÕģźÕēŹÕü£µŁó" / write-confirm).
  writeConfirm Boolean @map("write_confirm")

  @@map("account_settings")
}

/// Single-row system-wide settings (configurable-task-slots change).
///
/// Holds GLOBAL operator settings shared by every account ŌĆö explicitly NOT a
/// column on the per-account `AccountSettings` row (its `userId @unique`
/// scoping and cross-account isolation semantics are wrong for one shared
/// concurrency pool). The service layer addresses the single row via a FIXED
/// id upsert, so at most one row ever exists. Absence of the row means the
/// env seed applies: the effective ceiling resolves as
/// `dbSetting ?? env MAX_CONCURRENT_TASKS ?? 5`.
model SystemSettings {
  /// Fixed singleton id (the service upserts on a constant; no default ŌĆö the
  /// row is only ever created by the fixed-id upsert).
  id String @id

  /// The system-wide task concurrency ceiling (contracts constrain to 1ŌĆō20).
  maxConcurrentTasks Int @map("max_concurrent_tasks")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// Per-account Codex execution credential (account-settings spec).
///
/// Scoped one-per-user via the UNIQUE `userId`. This is the Codex EXECUTION
/// credential ("õ╗╗ÕŖĪĶ┐ÉĶĪīńö©õ╗Ćõ╣łµ©ĪÕ×ŗ"), entirely distinct from the console login
/// identity. Secret discipline: only `apiKeyCiphertext` (ENCRYPTED at rest ŌĆö the
/// ciphertext only, NEVER plaintext) is persisted for the key, alongside
/// `apiKeyLast4`, a masked suffix kept solely for display. The plaintext key is
/// never stored or returned. Mirrors the persisted side of `@cap/contracts`
/// `CodexCredentialSchema` / `SaveCodexCredentialRequestSchema`.
model CodexCredential {
  id     String @id @default(uuid())
  /// FK to the owning user; UNIQUE so there is at most one credential per account.
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Active provider mode: `official` | `compatible`.
  mode String

  /// Connection state: `not_connected` | `not_saved` | `connected`.
  state String

  /// Compatible-provider base URL (non-secret). Null for official mode.
  baseUrl String? @map("base_url")

  /// The API key ENCRYPTED at rest ŌĆö ciphertext only, never plaintext. Null when
  /// no key is stored.
  apiKeyCiphertext String? @map("api_key_ciphertext")

  /// Masked suffix of the stored key (e.g. last 4 chars) for display only. Null
  /// when no key is stored.
  apiKeyLast4 String? @map("api_key_last4")

  /// Selected default model persisted with the credential (non-secret). Null
  /// when unset.
  defaultModel String? @map("default_model")

  /// OFFICIAL-mode ChatGPT login state ŌĆö the full `~/.codex/auth.json` ENCRYPTED
  /// at rest (ciphertext.iv.authTag), never plaintext. The sandbox provider
  /// decrypts + injects it per task so the credential is configured in Settings
  /// (the official subscription entry) rather than a deployment env var. Null
  /// when no official login is stored.
  authJsonCiphertext String? @map("auth_json_ciphertext")

  @@map("codex_credentials")
}

/// Durable, container-independent index of a task's captured codex transcript
/// (persist-session-transcripts).
///
/// One row per task (keyed by the UNIQUE `taskId`, 1:1 with {@link Task}),
/// upserted on proactive terminal capture OR a later read-through backfill ŌĆö never
/// duplicated. The RAW, gzip-compressed rollout JSONL itself lives on the durable
/// per-task workspace volume at `archivePath`
/// (`workspaces/<taskId>/transcript.jsonl.gz`) and remains the SOURCE OF TRUTH;
/// this row is a derivable catalog entry that survives container reaping and lets
/// transcripts be looked up by id AND searched across history by content.
///
/// `model`/`cwd`/`startedAt`/`turnCount`/`isInterrupted` are the parsed session
/// meta. `content` is the concatenated turn text, made full-text searchable via a
/// Postgres GIN `tsvector` index added in the accompanying migration (Prisma has
/// no native `tsvector` type, so the index is declared in raw SQL, not here).
model SessionTranscript {
  id     String @id @default(uuid())
  /// FK to the owning task; UNIQUE so there is at most one transcript index row
  /// per task (1:1). Cascades when the task is deleted.
  taskId String @unique @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// Parsed session meta: the codex model id. Null when the rollout did not
  /// surface one.
  model         String?   @map("model")
  /// Parsed session meta: the working directory the session ran in. Null when
  /// absent from the rollout.
  cwd           String?   @map("cwd")
  /// Parsed session meta: when the codex session started. Null when absent.
  startedAt     DateTime? @map("started_at")
  /// Parsed session meta: number of turns in the transcript.
  turnCount     Int       @default(0) @map("turn_count")
  /// Parsed session meta: whether the session ended mid-flight (interrupted).
  isInterrupted Boolean   @default(false) @map("is_interrupted")

  /// Path to the RAW gzip-compressed rollout JSONL archive on the durable
  /// workspace volume (the source of truth).
  archivePath String   @map("archive_path")
  /// When this transcript was captured/last upserted.
  capturedAt  DateTime @default(now()) @map("captured_at")

  /// Concatenated transcript turn text, full-text-searchable across history via
  /// the Postgres GIN `tsvector` index declared in the migration.
  content String @map("content")

  @@map("session_transcripts")
}
