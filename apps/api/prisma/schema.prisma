// Prisma schema for the agent-control-platform orchestrator (apps/api).
//
// Track: repo-and-task-management.
// The `TaskStatus` enum mirrors the single-source-of-truth task-status enum in
// `@cap/contracts` (packages/contracts). Prisma cannot import the zod enum
// directly, so the values are kept byte-for-byte identical to the contracts
// `TaskStatus` literals; the lifecycle state machine validates the values it
// reads/writes against the contracts schema at runtime.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Task lifecycle states. MUST stay in sync with the contracts task-status enum.
/// `agent_failed_to_start` is a distinct terminal state, separate from a generic
/// `failed` and from `running`. `queued` is the admission-control holding state
/// used by the concurrency semaphore (guardrails track). `cancelled` is the
/// terminal state for an operator-initiated stop, distinct from both `completed`
/// (clean agent exit) and `failed` (crash / guardrail force-fail).
enum TaskStatus {
  pending
  queued
  running
  awaiting_input
  completed
  failed
  cancelled
  agent_failed_to_start
}

/// Console authorization role (add-private-account-identity).
///
/// `role` gates ONLY the admin panel (account-administration); it carries NO
/// execution privilege — every `allowed` account is host-root regardless of
/// role (the UI must never imply per-role sandboxing). MUST stay in sync with
/// the `@cap/contracts` `RoleSchema` values. Defaults to `member`.
enum Role {
  admin
  member
}

/// A registered repository the operator can launch tasks against.
///
/// Import metadata remains nullable for legacy rows. `defaultBranch` is
/// forge-neutral and stores a verified picker/API or symbolic-HEAD value;
/// description/branchCount/updatedAt/githubId remain GitHub provenance fields.
/// Names mirror the `@cap/contracts` `RepoSchema`.
model Repo {
  id        String   @id @default(uuid())
  /// Human-friendly display name.
  name      String
  /// Git source (clone URL / remote) the runner checks out from.
  gitSource String   @map("git_source")
  createdAt DateTime @default(now()) @map("created_at")

  /// GitHub repo description (import metadata). Null when not imported.
  description   String?   @map("description")
  /// Verified forge default branch. Null for legacy unverified rows.
  defaultBranch String?   @map("default_branch")
  /// GitHub branch count (import metadata). Null when not imported.
  branchCount   Int?      @map("branch_count")
  /// GitHub last-updated timestamp (import metadata). Null when not imported.
  updatedAt     DateTime? @map("updated_at")
  /// Originating GitHub repository identity, used to de-duplicate imports.
  /// Null when not imported from GitHub.
  githubId      String?   @map("github_id")
  /// Whether this imported Repo is the operator's current DEFAULT repo for
  /// task-creation selection. At most one Repo is ever `true`; designating a new
  /// default clears the prior one. Only an imported Repo may carry `true`.
  isDefault     Boolean   @default(false) @map("is_default")

  /// Source forge (add-multi-forge-task-delivery): `github` | `gitlab` | `gitee`.
  /// Null for repos predating multi-forge (inferred from the `gitSource` host at
  /// use). Drives change-request push-back forge selection.
  forge           String? @map("forge")
  /// Cached GitLab numeric project id (avoids the `%2F` url-encoded path). Null
  /// for non-gitlab / uncached.
  gitlabProjectId String? @map("gitlab_project_id")

  tasks     Task[]
  schedules TaskSchedule[]

  @@map("repos")
}

/// A single agent task scoped to one `Repo`.
model Task {
  id     String @id @default(uuid())
  /// FK to the owning repository.
  repoId String @map("repo_id")
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  /// Durable account owner for credential, recovery, and audit attribution.
  /// Nullable only for legacy/system tasks with no authenticated account.
  ownerUserId String? @map("owner_user_id")
  owner       User?   @relation("TaskOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  /// The operator-supplied prompt/instruction driving the agent.
  prompt String

  /// Current lifecycle state; defaults to `pending` on creation.
  status TaskStatus @default(pending)

  /// Monotonic lifecycle fence used by durable admission workers. Historical
  /// tasks start at zero; every later lifecycle compare-and-swap must increment
  /// this value so a superseded worker cannot cross an external boundary.
  lifecycleVersion Int @default(0) @map("lifecycle_version")

  /// Internal-only marker declaring that this task expects durable provisioning
  /// diagnostics. Both fields remain null for pre-ledger tasks so read paths can
  /// honestly project `unavailable` instead of fabricating evidence.
  provisioningDiagnosticSchemaVersion Int? @map("provisioning_diagnostic_schema_version")
  /// One-based counter atomically consumed when an actual provider attempt starts.
  provisioningDiagnosticNextAttempt   Int? @map("provisioning_diagnostic_next_attempt")

  /// Stable, secret-free runtime failure classification. Written atomically with
  /// the terminal `failed` status so read paths never observe a generic failure
  /// after the classifier has identified an actionable authentication problem.
  failureCode     String?   @map("failure_code")
  failureAt       DateTime? @map("failure_at")
  failureExitCode Int?      @map("failure_exit_code")

  /// Durable winners of the two admission CAS transitions. Keeping the token for
  /// each edge lets a worker resolve an ambiguous database acknowledgement even
  /// when a later worker has already advanced queued -> running.
  queuedAdmissionToken  String? @map("queued_admission_token")
  runningAdmissionToken String? @map("running_admission_token")

  /// Optional run parameter echoed back from the create body: the git branch the
  /// runner checks out. Inert with respect to the lifecycle; null when omitted.
  branch   String? @map("branch")
  /// Optional run parameter echoed back from the create body: the execution
  /// strategy. Inert with respect to the lifecycle; null when omitted.
  strategy String? @map("strategy")

  /// Optional run parameter: the skill/method ids (e.g. "openspec", "bmad") the
  /// operator chose to preinstall into the task workspace at provision time
  /// (task-preinstall-skills). Inert with respect to the lifecycle; empty when
  /// none were selected. Postgres text[] — echoed back on every task read path.
  skills String[] @default([]) @map("skills")

  /// Optional per-task guardrail parameter: the idle ceiling in milliseconds.
  /// Idle reclamation is OPT-IN and OFF by default — null means the task is never
  /// force-failed for idleness (unless an operator-level `MAX_IDLE_MS` default is
  /// configured). Consumed at admission to arm the idle watcher AND persisted so
  /// the configured value is readable on every task read path.
  idleTimeoutMs Int? @map("idle_timeout_ms")
  /// Optional per-task guardrail parameter: the wall-clock deadline in
  /// milliseconds from admission. Null means no deadline. Consumed at admission to
  /// arm the deadline watcher AND persisted (previously transient) so the
  /// configured value is readable on every task read path.
  deadlineMs    Int? @map("deadline_ms")

  /// Optional agent-runtime selector echoed back from the create body
  /// (`claude-code` | `codex`). Additive and NULLABLE: existing rows backfill to
  /// NULL and an omitted-on-create value reads back as the default `codex` (the
  /// service applies the default; the column itself stores null when unset).
  /// Persisted as text and kept in sync with the `@cap/contracts` `RuntimeSchema`
  /// values (add-claude-code-runtime).
  runtime String? @map("runtime")

  /// Exact normalized selector requested for this task. Null means the task
  /// intentionally follows the effective runtime/credential default.
  model String? @map("model")

  /// Non-secret immutable provider/toolchain snapshot used to validate an
  /// explicit model and later provision/recover the exact same environment.
  /// Internal only; canonical task responses expose `model`, not this JSON.
  executionEnvironmentSnapshot Json? @map("execution_environment_snapshot")

  /// Optional managed sandbox runtime environment selected for this task. Null
  /// means the task used the compatible managed default or the deployment-level
  /// fallback at provisioning time.
  sandboxEnvironmentId String?             @map("sandbox_environment_id")
  sandboxEnvironment   SandboxEnvironment? @relation(fields: [sandboxEnvironmentId], references: [id], onDelete: SetNull)

  /// The execution mode this task runs under (add-headless-execution-track):
  /// `interactive-pty` (console live terminal + operator takeover) or `headless-exec`
  /// (a programmatic one-shot that exits on turn completion). Additive + NULLABLE:
  /// existing rows backfill to NULL and an omitted value reads back as the default
  /// `interactive-pty` (the service applies the default; the column stores null when
  /// unset), mirroring `runtime`.
  executionMode String? @map("execution_mode")

  /// add-multi-forge-task-delivery — opt-in result delivery. All additive +
  /// NULLABLE. `deliver` echoes the create body (null reads back as `none`); the
  /// rest are populated by the push-back attempt at terminal (null until then).
  deliver             String? @map("deliver")
  deliverStatus       String? @map("deliver_status")
  branchPushed        String? @map("branch_pushed")
  commitSha           String? @map("commit_sha")
  changeRequestUrl    String? @map("change_request_url")
  changeRequestNumber Int?    @map("change_request_number")

  createdAt DateTime @default(now()) @map("created_at")

  /// Append-only audit events recorded for this task's lifecycle transitions.
  auditEvents AuditEvent[]

  /// The durable, container-independent transcript index for this task (zero or
  /// one). Populated at terminal capture or read-through backfill; survives
  /// container reaping (persist-session-transcripts).
  sessionTranscript SessionTranscript?

  /// Idempotency-key dedup records that admitted this task (zero or one per key).
  /// Recorded in the SAME transaction as the task create so a raced retry cannot
  /// double-admit a sandbox (public-v1-api).
  idempotencyKeys IdempotencyKey[]

  /// Provider-owned sandbox run records. Additive owner metadata for
  /// multi-provider readoption/delivery/teardown; one task may accumulate
  /// multiple attempts over time.
  sandboxRuns SandboxRun[]
  /// Nullable provenance relation for a task created by a schedule occurrence.
  /// Direct tasks have no row here; schedule-created tasks link through the
  /// one schedule-run record for their occurrence.
  scheduleRun TaskScheduleRun?

  /// Durable asynchronous admission outbox (zero or one). Historical tasks
  /// intentionally have no row; every newly accepted task gets exactly one.
  admissionWork TaskAdmissionWork?

  /// Bounded, secret-free provisioning evidence. These relations are internal
  /// and never expand the ordinary Task response.
  provisioningDiagnosticAttempts   TaskProvisioningDiagnosticAttempt[]
  provisioningDiagnosticCompaction TaskProvisioningDiagnosticCompaction?

  @@index([repoId])
  @@index([ownerUserId])
  @@index([sandboxEnvironmentId])
  @@map("tasks")
}

/// Durable, secret-free task-admission outbox. `taskId` is both the primary key
/// and task foreign key, making the relationship exactly zero-or-one per Task.
/// Lease identity is internal coordination metadata and is never projected on
/// public task responses. Cause values are stable codes, never raw diagnostics.
model TaskAdmissionWork {
  taskId String @id @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// Public-safe orchestration state. Kept in sync with the contracts
  /// provisioning-state vocabulary by migration CHECK constraints.
  state   String @default("accepted")
  /// Zero before the first claim; incremented once per processing attempt.
  attempt Int    @default(0)

  /// Earliest instant at which a fresh/retry claim may be acquired.
  availableAt DateTime  @default(now()) @map("available_at")
  /// Opaque worker identity and lease expiry. They are present as a pair only
  /// while the work item is in its active `running` or `parked` state. A
  /// parked row retains the parking worker's token as the ownership
  /// generation; its lease expiry is the parked recovery horizon.
  leaseOwner  String?   @map("lease_owner")
  leaseUntil  DateTime? @map("lease_until")

  /// Public-safe progress stage and optional terminal cause code. No command,
  /// provider endpoint, credential, or raw diagnostic has a persistence field.
  stage     String  @default("accepted")
  causeCode String? @map("cause_code")

  /// Write-once recovery snapshots. The database permits initial nulls for
  /// legacy/default-branch resolution, then prevents replacing a resolved value.
  resolvedBranch                     String? @map("resolved_branch")
  resourceSnapshot                   Json?   @map("resource_snapshot")
  /// Immutable workspace materialization deadline selected at admission. Null
  /// is retained only for rolling-upgrade and historical work compatibility.
  workspaceMaterializationDeadlineMs Int?    @map("workspace_materialization_deadline_ms")

  /// Latest detached workspace-transfer progress snapshot persisted by the
  /// parked poll loop; source for the provisioning-summary projection.
  /// Numeric-only by CHECK constraint. Null percent models an indeterminate
  /// phase explicitly and is never rendered as 0%.
  progressPercent                  Int?    @map("progress_percent")
  progressReceivedObjects          BigInt? @map("progress_received_objects")
  progressTotalObjects             BigInt? @map("progress_total_objects")
  progressReceivedBytes            BigInt? @map("progress_received_bytes")
  progressThroughputBytesPerSecond BigInt? @map("progress_throughput_bytes_per_second")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Supports deterministic available-work claims and polling after a missed
  /// in-process wake-up.
  @@index([state, availableAt, createdAt, taskId])
  /// Supports restart recovery of expired leases by state.
  @@index([state, leaseUntil, createdAt, taskId])
  @@map("task_admission_work")
}

/// Durable recurring task definition. A schedule is an intent to create future
/// ordinary Task rows; it is deliberately separate from TaskStatus.
model TaskSchedule {
  id String @id @default(uuid())

  ownerUserId String @map("owner_user_id")
  owner       User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  repoId String @map("repo_id")
  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)

  name         String?
  taskTemplate Json      @map("task_template")
  cron         String    @map("cron")
  timezone     String    @map("timezone")
  enabled      Boolean   @default(true)
  nextRunAt    DateTime? @map("next_run_at")

  overlapPolicy String @default("skip") @map("overlap_policy")
  misfirePolicy String @default("fire-once") @map("misfire_policy")

  claimToken String?   @map("claim_token")
  claimUntil DateTime? @map("claim_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  runs TaskScheduleRun[]

  @@index([ownerUserId, createdAt, id])
  @@index([enabled, nextRunAt])
  @@index([claimUntil])
  @@map("task_schedules")
}

/// Per-occurrence ledger for a claimed schedule fire. The unique
/// (scheduleId, scheduledFor) key is the durable de-duplication boundary for
/// multiple API processes or restart races.
model TaskScheduleRun {
  id String @id @default(uuid())

  scheduleId String       @map("schedule_id")
  schedule   TaskSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  scheduledFor      DateTime  @map("scheduled_for")
  /// Stable schedule-period identity. Null only for legacy rows created before
  /// period-aware dispatch; new manual and automatic runs always populate it.
  periodKey         String?   @map("period_key")
  /// Dispatch origin for period-aware runs (`manual` or `automatic`).
  triggerSource     String?   @map("trigger_source")
  /// Request/tick time that initiated the run, distinct from its nominal fire.
  triggeredAt       DateTime? @map("triggered_at")
  status            String
  taskId            String?   @unique @map("task_id")
  task              Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  error             String?
  /// Stable machine-readable pre-task model failure.
  errorCode         String?   @map("error_code")
  /// Next retry time for a transient pre-task catalog failure.
  retryAt           DateTime? @map("retry_at")
  /// One-based attempt count for the same durable occurrence.
  retryAttempt      Int?      @map("retry_attempt")
  /// Absolute bound after which the occurrence becomes terminal.
  retryHorizonAt    DateTime? @map("retry_horizon_at")
  /// Immutable normalized task-template snapshot captured on first retry.
  retryTaskTemplate Json?     @map("retry_task_template")

  /// Per-occurrence post-commit admission lease. Schedule-level claims protect
  /// cadence CAS; these fields prevent one interrupted run from blocking later
  /// occurrences of the same schedule.
  admissionClaimToken String?   @map("admission_claim_token")
  admissionClaimUntil DateTime? @map("admission_claim_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([scheduleId, scheduledFor])
  @@unique([scheduleId, periodKey])
  @@index([scheduleId, scheduledFor, id])
  @@index([status])
  @@index([status, admissionClaimUntil])
  @@index([status, retryAt])
  @@map("task_schedule_runs")
}

/// Admin-managed sandbox runtime environment. Source descriptors are non-secret
/// registry image references only; provider and registry credentials remain in
/// provider settings/env and are never stored here.
model SandboxEnvironment {
  id String @id @default(uuid())

  name   String
  source Json
  status String @default("draft")

  /// Non-secret provisioning-time resource policy. This is distinct from
  /// guest image parameters and remains nullable for pre-resource environments.
  resources Json?

  /// Admin-managed image runtime parameters. `envVars` stores readable plain
  /// values. `secretEnvVars` stores encrypted values and must never be returned
  /// on API read paths.
  envVars       Json @default("{}") @map("env_vars")
  secretEnvVars Json @default("{}") @map("secret_env_vars")

  providerFamilies String[] @default([]) @map("provider_families")
  runtimeIds       String[] @default([]) @map("runtime_ids")
  isDefault        Boolean  @default(false) @map("is_default")

  lastValidationId String? @map("last_validation_id")
  contractVersion  String? @map("contract_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks       Task[]
  validations SandboxEnvironmentValidation[]

  @@index([status, isDefault])
  @@map("sandbox_environments")
}

/// Validation/probe history for a sandbox environment. Records non-secret probe
/// metadata only; raw provider credentials and task secrets are never stored.
model SandboxEnvironmentValidation {
  id String @id @default(uuid())

  environmentId String             @map("environment_id")
  environment   SandboxEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  status                   String
  providerFamily           String  @map("provider_family")
  runtimeId                String? @map("runtime_id")
  sourceKind               String  @map("source_kind")
  resolvedLocator          String? @map("resolved_locator")
  resolvedDigest           String? @map("resolved_digest")
  resolvedChecksum         String? @map("resolved_checksum")
  runtimeArtifactChecksums Json?   @map("runtime_artifact_checksums")
  cliArtifactChecksum      String? @map("cli_artifact_checksum")
  sandboxMetadata          Json?   @map("sandbox_metadata")
  resourceSnapshot         Json?   @map("resource_snapshot")
  probes                   Json?   @map("probes")
  error                    String?
  contractVersion          String? @map("contract_version")

  checkedAt DateTime @default(now()) @map("checked_at")

  @@index([environmentId, checkedAt])
  @@map("sandbox_environment_validations")
}

/// Provider-owned sandbox run metadata for a task provision attempt.
///
/// This table stores routing/reattach metadata only. It MUST NOT store provider
/// credentials or task secrets; `connectionJson` is limited to addressable
/// non-secret handles such as task/base/ws URLs.
model SandboxRun {
  id String @id @default(uuid())

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  providerId         String  @map("provider_id")
  providerSandboxId  String? @map("provider_sandbox_id")
  /// Admission lease generation currently authorized to operate this run.
  ownerGeneration    String? @map("owner_generation")
  /// Immutable identity of the physical sandbox incarnation.
  resourceGeneration String? @map("resource_generation")
  /// Whether a provider create request may still produce a late resource.
  createState        String  @default("entered") @map("create_state")
  status             String  @default("running")
  connectionJson     Json?   @map("connection_json")
  metadata           Json?   @map("metadata")

  /// Secondary cleanup evidence only. `status` remains the sole cleanup
  /// authority; these fields must never settle or replace it.
  cleanupAttemptInFlight Boolean   @default(false) @map("cleanup_attempt_in_flight")
  cleanupAttemptCount    Int       @default(0) @map("cleanup_attempt_count")
  cleanupLastAttemptId   String?   @map("cleanup_last_attempt_id")
  cleanupLastOutcome     String?   @map("cleanup_last_outcome")
  cleanupLastProof       String?   @map("cleanup_last_proof")
  cleanupLastCause       String?   @map("cleanup_last_cause")
  cleanupLastRetryable   Boolean?  @map("cleanup_last_retryable")
  cleanupLastObservedAt  DateTime? @map("cleanup_last_observed_at")
  cleanupOrphanConfirmedAt DateTime? @map("cleanup_orphan_confirmed_at")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  terminalAt DateTime? @map("terminal_at")
  removedAt  DateTime? @map("removed_at")

  @@index([taskId, status])
  @@index([providerId, providerSandboxId])
  @@index([taskId, ownerGeneration, resourceGeneration])
  @@index([status, cleanupOrphanConfirmedAt])
  @@map("sandbox_runs")
}

/// One bounded, provider-neutral provisioning attempt. Diagnostic attempt
/// numbering is independent from admission claim counts and is allocated from
/// the owning Task only after running capacity has been won.
model TaskProvisioningDiagnosticAttempt {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  schemaVersion  Int     @map("schema_version")
  attempt        Int     @map("attempt_number")
  admissionMode  String  @map("admission_mode")
  providerFamily String? @map("provider_family")
  state          String
  stage          String
  coverage       String

  primaryOutcome    String?   @map("primary_outcome")
  primaryCause      String?   @map("primary_cause")
  primaryRetryable  Boolean?  @map("primary_retryable")
  primaryExitCode   Int?      @map("primary_exit_code")
  primaryObservedAt DateTime? @map("primary_observed_at")

  cleanupState              String    @default("not_required") @map("cleanup_state")
  cleanupCause              String?   @map("cleanup_cause")
  cleanupAttemptCount       Int       @default(0) @map("cleanup_attempt_count")
  cleanupLastAttemptOutcome String?   @map("cleanup_last_attempt_outcome")
  cleanupObservedAt         DateTime? @map("cleanup_observed_at")

  eventCount           Int       @default(0) @map("event_count")
  truncated            Boolean   @default(false)
  startedAt            DateTime  @default(now()) @map("started_at")
  finishedAt           DateTime? @map("finished_at")
  completenessMarkedAt DateTime? @map("completeness_marked_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  events TaskProvisioningDiagnosticEvent[]

  @@unique([taskId, attempt])
  @@unique([id, taskId])
  @@index([taskId, startedAt, id])
  @@index([taskId, state, cleanupState])
  @@index([state, startedAt])
  @@map("task_provisioning_diagnostic_attempts")
}

/// Append-only fixed-schema diagnostic event. Commands, output, URLs, headers,
/// provider identifiers, arbitrary JSON, and raw errors deliberately have no
/// persistence field.
model TaskProvisioningDiagnosticEvent {
  id        String                            @id @default(uuid())
  attemptId String                            @map("attempt_id")
  taskId    String                            @map("task_id")
  attempt   TaskProvisioningDiagnosticAttempt @relation(fields: [attemptId, taskId], references: [id, taskId], onDelete: Cascade)

  schemaVersion  Int      @map("schema_version")
  idempotencyKey String   @map("idempotency_key")
  sequence       Int
  operationId    String   @map("operation_id")
  admissionMode  String   @map("admission_mode")
  providerFamily String   @map("provider_family")
  stage          String
  operation      String
  channel        String
  commandKind    String?  @map("command_kind")
  outcome        String
  observedAt     DateTime @map("observed_at")

  durationMs      Int?     @map("duration_ms")
  cause           String?
  retryable       Boolean?
  httpStatusClass String?  @map("http_status_class")
  nativeState     String?  @map("native_state")
  anomaly         String?
  exitCode        Int?     @map("exit_code")
  timeoutMs       Int?     @map("timeout_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([attemptId, idempotencyKey])
  @@unique([attemptId, sequence])
  @@index([taskId, observedAt, id])
  @@map("task_provisioning_diagnostic_events")
}

/// Fixed-schema aggregate written transactionally before old settled attempt
/// detail is removed. Pending cleanup is never eligible for compaction.
model TaskProvisioningDiagnosticCompaction {
  taskId String @id @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  compactedAttemptFrom  Int @map("compacted_attempt_from")
  compactedAttemptTo    Int @map("compacted_attempt_to")
  compactedAttemptCount Int @map("compacted_attempt_count")
  compactedEventCount   Int @map("compacted_event_count")
  truncationCount       Int @map("truncation_count")

  primarySucceededCount     Int @default(0) @map("primary_succeeded_count")
  primaryFailedCount        Int @default(0) @map("primary_failed_count")
  primaryTimedOutCount      Int @default(0) @map("primary_timed_out_count")
  primaryCancelledCount     Int @default(0) @map("primary_cancelled_count")
  primaryDegradedCount      Int @default(0) @map("primary_degraded_count")
  primaryIndeterminateCount Int @default(0) @map("primary_indeterminate_count")

  cleanupNotRequiredCount Int @default(0) @map("cleanup_not_required_count")
  cleanupPendingCount     Int @default(0) @map("cleanup_pending_count")
  cleanupSucceededCount   Int @default(0) @map("cleanup_succeeded_count")
  cleanupFailedCount      Int @default(0) @map("cleanup_failed_count")

  compactedAt DateTime @map("compacted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("task_provisioning_diagnostic_compactions")
}

/// An authenticated GitHub operator identity (multi-user-oauth spec).
///
/// Keyed on the immutable GitHub numeric `id` (`githubId`), NOT the mutable
/// `login`, mirroring `@cap/contracts` `SessionUserSchema`. Contracts models
/// `githubId` as `z.number().int()`, so it is stored as `Int` here. `login`,
/// `name`, and `avatarUrl` are mutable profile fields refreshed on each login.
/// `allowed` is the load-bearing fail-closed allowlist gate: only an
/// allowlisted identity is ever surfaced as a session user.
model User {
  id                 String   @id @default(uuid())
  /// Stable, immutable GitHub numeric account id; the allowlist + user-record key.
  ///
  /// EXPAND-CONTRACT (add-private-account-identity): the github identity now also
  /// lives on an {@link IdentityLink} row (`provider="github"`,
  /// `providerAccountId=<this id>`). This column is KEPT for now so the backfill
  /// migration and the rollback window can read it; it is dropped in a later
  /// contract-step migration once all reads route through the github-identity
  /// helper. Now NULLABLE (integration step 10.1): local, non-GitHub accounts
  /// (the admin seed + admin-created accounts) have no GitHub id, and new GitHub
  /// logins persist the id on the `github` IdentityLink rather than on this
  /// column. Still `@unique` so existing GitHub rows keep their one-to-one mapping
  /// (Postgres does not unique-constrain NULLs, so many local accounts coexist).
  githubId           Int?     @unique @map("github_id")
  /// GitHub `login` (mutable username), refreshed on each login. NULLABLE
  /// (integration step 10.1): a local, non-GitHub account has no GitHub handle —
  /// only GitHub-provisioned accounts populate it.
  login              String?
  /// Display name, captured for console rendering (GitHub display name, or the
  /// email for a local account).
  name               String
  /// GitHub avatar reference, captured for console rendering. NULLABLE
  /// (integration step 10.1): a local account has no GitHub avatar.
  avatarUrl          String?  @map("avatar_url")
  /// Canonical account email (add-private-account-identity). UNIQUE but NULLABLE:
  /// a GitHub user without a verified primary email simply has none and can only
  /// use GitHub; every local account has one. The handle password/OTP login
  /// resolve against, and the auto-link key for a GitHub verified primary email.
  email              String?  @unique @map("email")
  /// Console authorization role (add-private-account-identity). Gates ONLY the
  /// admin panel — NO execution privilege (every `allowed` account is host-root).
  /// Defaults to `member`; the default-admin seed sets `admin`.
  role               Role     @default(member)
  /// Forced first-login password change (add-private-account-identity). When true
  /// the AuthGuard denies every protected action except change-password (and
  /// logout) until a new password is set. Defaults to false; the seeded admin and
  /// admin-created local accounts set it true.
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  /// Whether this identity is presently on the fail-closed allowlist. This is the
  /// load-bearing runtime gate (add-private-account-identity): every authenticated
  /// request re-confirms `allowed`, uniformly for local and GitHub accounts.
  allowed            Boolean
  /// CONTRACT step done (add-private-account-identity, task 10.4): the operator's
  /// GitHub OAuth access token column (`github_access_token`) has been DROPPED. The
  /// token now lives ONLY as the (encrypted-at-rest) `secret` of the user's
  /// `github` {@link IdentityLink}, read through the shared github-identity helper
  /// (import/clone/forge all route through it — zero column reads remained, which
  /// is what made the drop safe). The `github_id` column is retained for now (it is
  /// still the owner-resolution key for the settings/forge/api-key/mcp surfaces and
  /// the session payload); dropping it is deferred to a later migration once those
  /// reads move to the stable `User.id` / the github IdentityLink.
  createdAt          DateTime @default(now()) @map("created_at")

  /// Each login identity for this account (add-private-account-identity): a
  /// `github` link (secret = encrypted access token), a `password` link
  /// (secret = argon2 hash), and room for future providers. Cascade-deleted with
  /// the owning user. Named `identities` (the relation the account-admin + seed
  /// tracks read/create through); the model is `IdentityLink`.
  identities       IdentityLink[]
  sessions         Session[]
  /// Per-user machine-identity API keys (api-key-machine-identity). Hash-only,
  /// revocable, cascade-deleted with the owning user.
  apiKeys          ApiKey[]
  /// Per-user remote-MCP machine tokens (remote-mcp-server). Hash-only,
  /// revocable, cascade-deleted with the owning user. Mirrors the `apiKeys`
  /// machine-identity relation but carries the distinct `mcp_` audience.
  mcpTokens        McpToken[]
  /// Audit events attributed to this GitHub-identity user (nullable on the
  /// event side for system-originated events).
  auditEvents      AuditEvent[]
  /// Per-account console preferences (zero or one).
  accountSettings  AccountSettings?
  /// Per-account Codex execution credential (zero or one).
  codexCredential  CodexCredential?
  claudeCredential ClaudeCredential?
  /// Per-account forge push-back credentials (add-forge-credentials) — one per
  /// (kind, host), encrypted, cascade-deleted with the owning user.
  forgeCredentials ForgeCredential[]
  /// Durable task schedules owned by this account.
  taskSchedules    TaskSchedule[]
  ownedTasks       Task[]            @relation("TaskOwner")

  @@map("users")
}

/// A single login identity attached to a {@link User} (add-private-account-identity).
///
/// The normalized identity model (D1): "who you are" (`User`) is separated from
/// "how you prove it" (this row). Each row is a distinct login method for one
/// account; a single `User` MAY hold several (e.g. both a `github` and a
/// `password` link). `provider` is the identity kind (`github` | `password`,
/// with room for future providers); `providerAccountId` is that provider's
/// stable account handle — the numeric GitHub id for `github`, the email for
/// `password`. The UNIQUE `(provider, providerAccountId)` makes a presented
/// identity resolve to at most one account and rejects a duplicate.
///
/// `secret` carries the identity's at-rest credential and is NEVER plaintext:
/// for `github` it is the encrypted GitHub access token (the same
/// `ciphertext.iv.authTag` envelope previously on `User.githubAccessToken`, read
/// through the shared github-identity helper via `readMaybeEncrypted`); for
/// `password` it is the argon2 hash. It is NULLABLE: a future provider whose
/// secret lives elsewhere (or an identity with no stored secret) leaves it null.
/// OTP is intentionally NOT an identity row — it is a login method keyed on
/// `User.email` whose codes live in {@link EmailOtp}. Rows cascade with the user.
model IdentityLink {
  id     String @id @default(uuid())
  /// FK to the owning account; cascades on user delete.
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Identity kind: `github` | `password` (room for future providers).
  provider          String @map("provider")
  /// The provider's stable account handle: the numeric GitHub id (as text) for
  /// `github`, the email for `password`.
  providerAccountId String @map("provider_account_id")

  /// The identity's at-rest credential, NEVER plaintext: the encrypted GitHub
  /// access token for `github`, the argon2 hash for `password`. Null when the
  /// identity stores no secret here.
  secret String? @map("secret")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("identity_links")
}

/// A single-use emailed verification code (add-private-account-identity, OTP login).
///
/// OTP is a login METHOD keyed on `User.email`, not an {@link IdentityLink}; this
/// table holds the issued codes. The code is stored HASHED at rest (SHA-256, same
/// discipline as session tokens) in `codeHash` — never plaintext. `email` is the
/// requested address (an unknown email is accepted with a uniform response and
/// simply never matches an allowed account). A code is valid only while
/// `now < expiresAt`, `consumedAt IS NULL`, and `attempts` is under the cap;
/// `consumedAt` is stamped on successful verify so a code cannot be replayed.
/// `attempts` bounds wrong-code guesses; the issuing flow enforces a resend
/// cooldown on top of this. Rows are short-lived (default ~10-minute TTL) and may
/// be reaped after expiry.
model EmailOtp {
  id String @id @default(uuid())

  /// The email the code was requested for (not necessarily an existing account).
  email String @map("email")

  /// HASH of the 6-digit code (never the raw code). SHA-256, like session tokens.
  codeHash String @map("code_hash")

  /// Absolute expiry; a code past this no longer verifies.
  expiresAt DateTime @map("expires_at")

  /// When the code was consumed by a successful verify; null while unused. A
  /// consumed code cannot be replayed.
  consumedAt DateTime? @map("consumed_at")

  /// Wrong-code attempt counter, bounded by the attempt cap.
  attempts Int @default(0) @map("attempts")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("email_otps")
}

/// An opaque server-side session for an authenticated {@link User}.
///
/// `tokenHash` stores a HASH of the opaque session token, never the raw token,
/// so a database read can never recover a usable credential. Sessions cascade
/// when the owning user is deleted.
model Session {
  id        String   @id @default(uuid())
  /// FK to the owning user.
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// HASH of the opaque session token (never the raw token).
  tokenHash String   @map("token_hash")
  /// Absolute expiry; a session past this is treated as unauthenticated.
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tokenHash])
  @@index([userId])
  @@map("sessions")
}

/// A per-user, revocable remote-MCP machine token (remote-mcp-server).
///
/// Mirrors {@link Session}'s hash-only discipline (and the api-key machine
/// identity it is modeled on): `tokenHash` stores a HASH of the opaque token
/// body (`randomBytes(32).base64url` → plain SHA-256) carrying the reserved
/// `mcp_` prefix, never the raw token, so a database read can never recover a
/// usable credential. The raw token is surfaced exactly ONCE at mint time; only
/// the non-secret `prefix` (`mcp_`) and the masked `last4` suffix are persisted
/// for display. `scopes` is the route-boundary authorization set (a subset of
/// the contracts `Scope` enum). `lastUsedAt` is a best-effort, staleness-
/// throttled bump off the hot auth path. A token past `expiresAt` or with
/// `revokedAt` set is treated as unauthenticated; `resolveMcpToken` additionally
/// re-checks the owner's allowlist on every request. A distinct model + `mcp_`
/// prefix keeps the MCP audience separate from the `cap_sk_` api-key principal
/// so MCP tokens are listed/revoked independently in their own settings card.
/// Tokens cascade when the owning user is deleted.
model McpToken {
  id        String   @id @default(uuid())
  /// FK to the owning user.
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// HASH of the opaque token body (never the raw token). UNIQUE so a presented
  /// token resolves to at most one record.
  tokenHash String   @unique @map("token_hash")
  /// Non-secret reserved credential prefix (`mcp_`), persisted for display.
  prefix    String   @map("prefix")
  /// Masked suffix of the raw token (last 4 chars) for display only.
  last4     String   @map("last4")
  /// Operator-supplied human-friendly label for the token.
  name      String   @map("name")
  /// Route-boundary authorization scopes (a subset of the contracts `Scope`
  /// enum). Postgres text[].
  scopes    String[] @map("scopes")

  /// Best-effort, staleness-throttled last-use timestamp. Null until first use.
  lastUsedAt DateTime? @map("last_used_at")
  /// Absolute expiry; a token past this is treated as unauthenticated. Null
  /// means no expiry.
  expiresAt  DateTime? @map("expires_at")
  /// Revocation timestamp; a token with this set is treated as unauthenticated.
  /// Null means active.
  revokedAt  DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("mcp_tokens")
}

/// A per-user, revocable machine-identity API key (api-key-machine-identity).
///
/// Mirrors {@link Session}'s hash-only discipline: `tokenHash` stores a HASH of
/// the opaque `cap_sk_…` key body (`randomBytes(32).base64url` → plain SHA-256),
/// never the raw key, so a database read can never recover a usable credential.
/// The raw key is surfaced exactly ONCE at mint time; only the non-secret
/// `prefix` (`cap_sk_`) and the masked `last4` suffix are persisted for display.
/// `scopes` is the route-boundary authorization set (a subset of the contracts
/// `Scope` enum). `lastUsedAt` is a best-effort, staleness-throttled bump off the
/// hot auth path. A key past `expiresAt` or with `revokedAt` set is treated as
/// unauthenticated; resolution additionally re-checks the owner's allowlist on
/// every request. Keys cascade when the owning user is deleted.
model ApiKey {
  id        String   @id @default(uuid())
  /// FK to the owning user.
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// HASH of the opaque key body (never the raw key). UNIQUE so a presented key
  /// resolves to at most one record.
  tokenHash String   @unique @map("token_hash")
  /// Non-secret reserved credential prefix (`cap_sk_`), persisted for display.
  prefix    String   @map("prefix")
  /// Masked suffix of the raw key (last 4 chars) for display only.
  last4     String   @map("last4")
  /// Operator-supplied human-friendly label for the key.
  name      String   @map("name")
  /// Route-boundary authorization scopes (a subset of the contracts `Scope`
  /// enum). Postgres text[].
  scopes    String[] @map("scopes")

  /// Best-effort, staleness-throttled last-use timestamp. Null until first use.
  lastUsedAt DateTime? @map("last_used_at")
  /// Absolute expiry; a key past this is treated as unauthenticated. Null means
  /// no expiry.
  expiresAt  DateTime? @map("expires_at")
  /// Revocation timestamp; a key with this set is treated as unauthenticated.
  /// Null means active.
  revokedAt  DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("api_keys")
}

/// An immutable, append-only audit event (audit-history spec).
///
/// One row is written at the moment of each task lifecycle transition and
/// notable operational outcome. By convention these rows are NEVER mutated or
/// deleted by lifecycle progression: a task's full ordered history stays
/// queryable even after it reaches a terminal state. Every event references a
/// REAL task id via the `taskId` FK and is never orphaned (cascade on task
/// delete). `userId` attributes the event to the GitHub-identity operator under
/// whom the action occurred; it is NULLABLE for system-originated events with no
/// attributed user.
///
/// Shape mirrors `@cap/contracts` `AuditEventSchema`. The contracts `userId`
/// wire field is the GitHub numeric account id (`githubId`); at this storage
/// layer the column is an FK to `users.id` (the user-record key), and the
/// service maps between the two.
model AuditEvent {
  id     String @id @default(uuid())
  /// FK to the owning task; every event references a real task and cascades on
  /// task delete.
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// FK to the attributed GitHub-identity user (the operator the action occurred
  /// under). NULL for system-originated events with no attributed user.
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  /// The lifecycle/audit kind, e.g. `task.created`, `task.running`,
  /// `task.completed`, `task.failed`, `task.cancelled`, `agent_failed_to_start`,
  /// `force_failed`.
  type String

  /// Severity governing the colored audit-dot: `info` | `warning` | `error`.
  level String

  /// Short, human-readable title for the timeline row.
  title String

  /// Human-readable description; for a force-fail it names the cause (deadline /
  /// idle / circuit-break).
  description String

  /// Server-assigned UTC timestamp at which the event was recorded.
  timestamp DateTime @default(now())

  /// Optional HTTP-status-like result code the console renders verbatim
  /// (`201`/`200`/`409`/`422`). Null when the event carries no result code.
  resultCode Int? @map("result_code")

  /// Session linkage: the most recent run identifier where one applies, letting
  /// the console deep-link the event's task to its live session route. Null when
  /// the event has no associated run.
  runId String? @map("run_id")

  /// Optional idempotency key for lifecycle events that have one durable
  /// identity. Null keeps ordinary transition/detail events append-only.
  dedupeKey String? @unique @map("dedupe_key")

  @@index([taskId, timestamp])
  @@index([timestamp])
  @@map("audit_events")
}

/// Per-account console preferences (account-settings spec).
///
/// Scoped one-per-user via the UNIQUE `userId`. `allowedAccount` is intentionally
/// NOT stored: it is the read-only allowlisted account display identity sourced
/// from the OAuth identity at read time. `defaultRepoId` references an imported
/// `Repo` by id and is NULLABLE; it is validated in the service layer (the
/// account must have imported that repo) rather than enforced as a DB FK.
/// Mirrors `@cap/contracts` `AccountSettingsSchema` (writable fields only).
model AccountSettings {
  id     String @id @default(uuid())
  /// FK to the owning user; UNIQUE so there is at most one settings row per
  /// account.
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Selected default repository (a `Repo` id), or null when unset. Validated in
  /// the service layer, not enforced as a DB foreign key.
  defaultRepoId String? @map("default_repo_id")

  /// User-scoped default sandbox image/environment for new tasks, or null when
  /// unset. Validated in the service layer, not enforced as a DB foreign key so
  /// deleting an environment can degrade to the deployment fallback on read.
  defaultSandboxEnvironmentId String? @map("default_sandbox_environment_id")

  /// History/audit retention window in days (contracts constrains to 7/30/90/180).
  retention Int

  /// Destructive-action gate toggle ("破坏性写入前停止" / write-confirm).
  writeConfirm Boolean @map("write_confirm")

  @@map("account_settings")
}

/// Single-row system-wide settings (configurable-task-slots change).
///
/// Holds GLOBAL operator settings shared by every account — explicitly NOT a
/// column on the per-account `AccountSettings` row (its `userId @unique`
/// scoping and cross-account isolation semantics are wrong for one shared
/// concurrency pool). The service layer addresses the single row via a FIXED
/// id upsert, so at most one row ever exists. Absence of the row means the
/// env seed applies: the effective ceiling resolves as
/// `dbSetting ?? env MAX_CONCURRENT_TASKS ?? 5`.
model SystemSettings {
  /// Fixed singleton id (the service upserts on a constant; no default — the
  /// row is only ever created by the fixed-id upsert).
  id String @id

  /// The system-wide task concurrency ceiling (contracts constrain to 1–20).
  maxConcurrentTasks Int @map("max_concurrent_tasks")

  /// Whether the remote MCP server (`/mcp`) is served (remote-mcp-server). Off
  /// by default — the outward-facing sandbox-execution surface ships inert and
  /// requires a deliberate admin enable. When `false`, `/mcp` serves no MCP
  /// traffic and no `mcp_` token resolves a usable session there; turning it
  /// off stops new use without deleting any minted token.
  mcpServerEnabled Boolean @default(false) @map("mcp_server_enabled")

  /// One-time default-admin credential reveal gate (add-private-account-identity).
  /// Null means the generated admin password has NOT yet been revealed; the
  /// reveal endpoint serves `{email, password}` exactly once and stamps this
  /// timestamp, after which any further reveal returns nothing. The plaintext
  /// itself is never persisted — it lives only in process memory until consumed
  /// or the process restarts (which regenerates it while this stays null).
  adminRevealConsumedAt DateTime? @map("admin_reveal_consumed_at")

  /// One-time env→DB SMTP migration marker (add-smtp-config-ui). Null means the
  /// boot seed has NOT yet copied the `SMTP_*` env into the singleton
  /// {@link SmtpConfig} row; once stamped the migration NEVER re-seeds — so an
  /// admin who later edits or deletes the DB config is not overwritten on a
  /// subsequent boot. Mirrors the single-boot discipline of
  /// `adminRevealConsumedAt`.
  smtpEnvMigratedAt DateTime? @map("smtp_env_migrated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// Singleton deployment-level SMTP configuration (add-smtp-config-ui).
///
/// SMTP is ONE outbound server for the whole deployment, so this is a GLOBAL
/// singleton (a fixed-id upsert, like {@link SystemSettings}) — explicitly NOT
/// keyed by `userId` (unlike {@link CodexCredential}). Outbound mail resolves
/// this DB row FIRST and falls back to the `SMTP_*` env when it is absent, so
/// existing env deployments are unaffected until an admin saves a config.
///
/// Secret discipline (mirrors {@link CodexCredential}): the password is persisted
/// ONLY as `passCiphertext` (ENCRYPTED at rest via the shared `secret-storage`
/// envelope — ciphertext only, NEVER plaintext) alongside `passLast4`, a masked
/// suffix kept solely for display. The non-secret host/port/user/from are stored
/// in the clear. A read NEVER returns the plaintext password.
model SmtpConfig {
  /// Fixed singleton id (the service upserts on a constant; no default — the row
  /// is only ever created by the fixed-id upsert).
  id String @id

  /// SMTP host (non-secret), e.g. `smtp.resend.com`.
  host String

  /// SMTP port (non-secret), e.g. `465`.
  port Int

  /// SMTP username (non-secret), e.g. `resend`.
  user String

  /// Sender address used as the `From:` header (non-secret).
  from String

  /// The SMTP password ENCRYPTED at rest — ciphertext only, never plaintext. Null
  /// when no password is stored.
  passCiphertext String? @map("pass_ciphertext")

  /// Masked suffix of the stored password (last 4 chars) for display only. Null
  /// when no password is stored.
  passLast4 String? @map("pass_last4")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("smtp_config")
}

/// Per-account Codex execution credential (account-settings spec).
///
/// Scoped one-per-user via the UNIQUE `userId`. This is the Codex EXECUTION
/// credential ("任务运行用什么模型"), entirely distinct from the console login
/// identity. Secret discipline: only `apiKeyCiphertext` (ENCRYPTED at rest — the
/// ciphertext only, NEVER plaintext) is persisted for the key, alongside
/// `apiKeyLast4`, a masked suffix kept solely for display. The plaintext key is
/// never stored or returned. Mirrors the persisted side of `@cap/contracts`
/// `CodexCredentialSchema` / `SaveCodexCredentialRequestSchema`.
model CodexCredential {
  id     String @id @default(uuid())
  /// FK to the owning user; UNIQUE so there is at most one credential per account.
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Active provider mode: `official` | `compatible`.
  mode String

  /// Connection state: `not_connected` | `not_saved` | `connected`.
  state String

  /// Compatible-provider base URL (non-secret). Null for official mode.
  baseUrl String? @map("base_url")

  /// The API key ENCRYPTED at rest — ciphertext only, never plaintext. Null when
  /// no key is stored.
  apiKeyCiphertext String? @map("api_key_ciphertext")

  /// Masked suffix of the stored key (e.g. last 4 chars) for display only. Null
  /// when no key is stored.
  apiKeyLast4 String? @map("api_key_last4")

  /// Selected default model persisted with the credential (non-secret). Null
  /// when unset.
  defaultModel String? @map("default_model")

  /// OFFICIAL-mode ChatGPT login state — the full `~/.codex/auth.json` ENCRYPTED
  /// at rest (ciphertext.iv.authTag), never plaintext. The sandbox provider
  /// decrypts + injects it per task so the credential is configured in Settings
  /// (the official subscription entry) rather than a deployment env var. Null
  /// when no official login is stored.
  authJsonCiphertext String? @map("auth_json_ciphertext")

  @@map("codex_credentials")
}

/// The per-account Claude Code execution credential ("Claude Code 任务用什么登录"),
/// the runtime sibling of {@link CodexCredential} (pixel-restore-console-to-od
/// Track 3 / account-settings "Claude Code runtime credential"). Distinct from the
/// console login identity and from the Codex credential. Two mutually-exclusive
/// modes:
///   - `subscription`: a Claude OAuth token minted on a workstation via
///     `claude setup-token`, stored ENCRYPTED at rest in `setup_token_ciphertext`
///     (ciphertext.iv.authTag), exported as `CLAUDE_CODE_OAUTH_TOKEN` to the
///     sandbox launch env by the runtime — the path the runtime consumes today.
///   - `api_key`: an Anthropic `sk-ant-` API key, stored ENCRYPTED in
///     `api_key_ciphertext` (usage-based billing). [follow-up: the runtime
///     currently injects only the OAuth token and unsets ANTHROPIC_API_KEY, so
///     api_key-mode INJECTION is a later runtime change; storage/masking ship now.]
/// Secret discipline mirrors Codex: only ciphertext + a masked `*Last4` suffix are
/// persisted; plaintext is never stored or returned.
model ClaudeCredential {
  id     String @id @default(uuid())
  /// FK to the owning user; UNIQUE so there is at most one credential per account.
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Active mode: `subscription` | `api_key`.
  mode String

  /// Connection state: `not_connected` | `not_saved` | `connected`.
  state String

  /// `claude setup-token` OAuth token ENCRYPTED at rest — ciphertext only, never
  /// plaintext. Null when no subscription token is stored.
  setupTokenCiphertext String? @map("setup_token_ciphertext")

  /// Masked suffix of the stored setup-token for display only. Null when unset.
  setupTokenLast4 String? @map("setup_token_last4")

  /// Anthropic API key ENCRYPTED at rest — ciphertext only. Null when unset.
  apiKeyCiphertext String? @map("api_key_ciphertext")

  /// Masked suffix of the stored API key for display only. Null when unset.
  apiKeyLast4 String? @map("api_key_last4")

  /// Selected default Claude model persisted with the credential (non-secret).
  defaultModel String? @map("default_model")

  @@map("claude_credentials")
}

/// A per-account code-hosting (forge) push-back credential (add-forge-credentials).
/// The write-scoped token used to clone/push and open a PR/MR on the operator's
/// own connected forge. Sibling of {@link CodexCredential}: only the ENCRYPTED
/// `tokenCiphertext` (the joined `ciphertext.iv.authTag` envelope, never plaintext)
/// plus a masked `tokenLast4` are persisted; the plaintext PAT is never stored or
/// returned. Keyed on (userId, kind, host) so one operator may connect several
/// forges / self-hosted hosts. `host` is always the forge host (github.com /
/// gitlab.com / gitee.com for public, or a self-hosted host) so the unique key is
/// exact (a NULL host would defeat the unique constraint in Postgres).
model ForgeCredential {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Forge kind: `github` | `gitlab` | `gitee`.
  kind String

  /// The forge host (public well-known host or a self-hosted host). Always set.
  host String

  /// The forge PAT ENCRYPTED at rest as the joined `ciphertext.iv.authTag` string
  /// — ciphertext only, never plaintext.
  tokenCiphertext String @map("token_ciphertext")

  /// Masked suffix of the stored token for display only. Null when unset.
  tokenLast4 String? @map("token_last4")

  /// Connection state: `connected` | `not_connected`.
  state String

  /// API/listing validation status: `verified` | `unverified`. `unverified`
  /// credentials are still connected for git clone/push; only repo-list/API use
  /// is not proven.
  apiAccess String @default("verified") @map("api_access")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, kind, host])
  @@index([userId])
  @@map("forge_credentials")
}

/// Operator-configured self-hosted forge registry (add-forge-credentials): maps a
/// self-hosted `host` to its forge `kind` + API base so change C can resolve a repo
/// on that host to a forge. Deployment-level infra config (NOT per-user), hence
/// `host` is the primary key. Public hosts (github.com / gitlab.com / gitee.com)
/// need no row — they are inferred. A forge call is a trusted call to the operator's
/// own forge, so it is NOT routed through `assertSafeProviderUrl`; a private/LAN
/// host is allowed.
model ForgeConnection {
  /// Self-hosted forge host, e.g. git.corp.com.
  host String @id

  /// Forge kind: `github` | `gitlab` | `gitee`.
  kind String

  /// API base, e.g. https://git.corp.com/api/v4 (/api/v3 GHE, /api/v4 GitLab,
  /// /api/v5 Gitee).
  apiBaseUrl String @map("api_base_url")

  /// Cached GitLab numeric project id (avoids the `%2F` url-encoded path). Null for
  /// non-gitlab / uncached.
  projectId String? @map("project_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("forge_connections")
}

/// Durable, container-independent index of a task's captured codex transcript
/// (persist-session-transcripts).
///
/// One row per task (keyed by the UNIQUE `taskId`, 1:1 with {@link Task}),
/// upserted on proactive terminal capture OR a later read-through backfill — never
/// duplicated. The RAW, gzip-compressed rollout JSONL itself lives on the durable
/// per-task workspace volume at `archivePath`
/// (`workspaces/<taskId>/transcript.jsonl.gz`) and remains the SOURCE OF TRUTH;
/// this row is a derivable catalog entry that survives container reaping and lets
/// transcripts be looked up by id AND searched across history by content.
///
/// `model`/`cwd`/`startedAt`/`turnCount`/`isInterrupted` are the parsed session
/// meta. `content` is the concatenated turn text, made full-text searchable via a
/// Postgres GIN `tsvector` index added in the accompanying migration (Prisma has
/// no native `tsvector` type, so the index is declared in raw SQL, not here).
model SessionTranscript {
  id     String @id @default(uuid())
  /// FK to the owning task; UNIQUE so there is at most one transcript index row
  /// per task (1:1). Cascades when the task is deleted.
  taskId String @unique @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// Parsed session meta: the codex model id. Null when the rollout did not
  /// surface one.
  model         String?   @map("model")
  /// Parsed session meta: the working directory the session ran in. Null when
  /// absent from the rollout.
  cwd           String?   @map("cwd")
  /// Parsed session meta: when the codex session started. Null when absent.
  startedAt     DateTime? @map("started_at")
  /// Parsed session meta: number of turns in the transcript.
  turnCount     Int       @default(0) @map("turn_count")
  /// Parsed session meta: whether the session ended mid-flight (interrupted).
  isInterrupted Boolean   @default(false) @map("is_interrupted")

  /// Path to the RAW gzip-compressed rollout JSONL archive on the durable
  /// workspace volume (the source of truth).
  archivePath String   @map("archive_path")
  /// When this transcript was captured/last upserted.
  capturedAt  DateTime @default(now()) @map("captured_at")

  /// Concatenated transcript turn text, full-text-searchable across history via
  /// the Postgres GIN `tsvector` index declared in the migration.
  content String @map("content")

  @@map("session_transcripts")
}

/// A per-principal idempotency record for `POST /v1/tasks` (public-v1-api).
///
/// `POST /v1/tasks` accepts an optional `Idempotency-Key` header. The dedup row
/// is INSERTED in the SAME transaction as the `Task`, its unique admission work,
/// and creation audit, so a raced retry can never commit a second work item: the
/// UNIQUE `([scopeUserId, key])` makes the second insert fail, and the handler
/// then returns the already-recorded `taskId`.
///
/// Scope semantics: `scopeUserId` is the PER-PRINCIPAL scope string (the api-key
/// owner / session user identity), NOT a hard FK — the principal kind is not
/// guaranteed to be a `users.id` row, so the column stays a plain scoped
/// identifier and the dedup is scoped to it. `key` is the caller-supplied header
/// value; `requestHash` is a hash of the canonicalized request body, used to
/// reject a reused key carrying a DIFFERENT body with 409. `taskId` FK-links to
/// the task the key admitted (cascades on task delete). `expiresAt` bounds the
/// dedup window to 24h from creation.
model IdempotencyKey {
  id String @id @default(uuid())

  /// Caller-supplied `Idempotency-Key` header value.
  key String @map("key")

  /// Per-principal scope (the api-key owner / session user identity). A plain
  /// scoped identifier, NOT a DB FK: the dedup is scoped per principal but the
  /// principal kind is not guaranteed to be a `users.id` row.
  scopeUserId String @map("scope_user_id")

  /// Hash of the canonicalized request body. A reused key with a DIFFERENT body
  /// (mismatched hash) is rejected with 409.
  requestHash String @map("request_hash")

  /// FK to the task this key admitted; cascades when the task is deleted.
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// When the dedup record was created.
  createdAt DateTime @default(now()) @map("created_at")

  /// Absolute expiry (creation + 24h); a record past this no longer dedups.
  expiresAt DateTime @map("expires_at")

  @@unique([scopeUserId, key])
  @@index([taskId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}
