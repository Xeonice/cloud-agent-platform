{
  "name": "@cap/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "prisma generate && nest build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "pretest": "pnpm -w exec turbo run build --filter=@cap/api",
    "test": "pnpm run test:compiled && pnpm run test:sandbox-src && pnpm run test:terminal-src",
    "test:compiled": "node --test --test-force-exit \"dist/**/*.spec.js\"",
    "test:sandbox-src": "node --test --test-force-exit \"src/sandbox/*.test.mjs\" \"src/guardrails/retention-cleaner.test.mjs\" \"src/tasks/startup-recovery.test.mjs\"",
    "test:terminal-src": "node --test --test-force-exit \"src/terminal/cast-writer.test.mjs\" \"src/terminal/codex-launch.test.mjs\" \"src/terminal/provider-terminal-story.service.test.mjs\" \"src/terminal/reconnect-replay.test.mjs\" \"src/terminal/concurrent-attach-single-writer.test.mjs\" \"src/terminal/readoption-history.test.mjs\"",
    "test:e2e": "node --env-file=../../.env --test --test-force-exit test/api-e2e.mjs",
    "pretest:e2e": "pnpm -w exec turbo run build --filter=@cap/api",
    "test:e2e:aio": "bash ../../scripts/aio-e2e.sh"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@cap/contracts": "workspace:*",
    "@cap/sandbox": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-ws": "^10.4.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^10.4.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/headless": "^5.5.0",
    "dockerode": "^5.0.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-dist": "^5.18.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cap/eslint-config": "workspace:*",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/ws": "^8.5.12",
    "eslint": "^9.27.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "typescript": "^5.5.0"
  }
}
