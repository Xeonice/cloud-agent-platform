# apps/api/.env — backend secrets/config for the docker-compose self-host target.
# Copy to apps/api/.env and fill in. NEVER commit the real .env (gitignored).
# Consumed via docker-compose.yml `env_file`.
#
# This instance is OAUTH-FIRST: a production self-host authenticates operators
# via a GitHub OAuth app + a hard allowlist. The legacy operator-token path is
# OFF by default and is needed ONLY for local dev — see the Auth section below.
# Full walkthrough: docs/self-hosting.md.

# ── Auth: GitHub OAuth App (the primary, required path) ───────────────────────
# Create a GitHub OAuth app and paste its credentials here. The login flow
# refuses to start unless BOTH are set (fail-closed).
#   Authorization callback URL: <api-origin>/auth/github/callback
#   (e.g. https://cap-api.example.com/auth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional. The redirect URI sent to GitHub at authorize time. Leave UNSET to
# use the app's registered "Authorization callback URL" default; set it only if
# you need to override that (must match a callback registered on the OAuth app).
GITHUB_OAUTH_REDIRECT_URI=

# GitHub login-time PROVISIONING list — comma-separated immutable NUMERIC GitHub
# user ids (NOT usernames). Find an id at https://api.github.com/users/<login>.
#   e.g. AUTH_ALLOWLIST=583231,1024025
#
# SEMANTICS CHANGED (add-private-account-identity): this is now consulted ONLY at
# GitHub login time to decide whether to provision/keep a GitHub user as
# `allowed`. It is NO LONGER the runtime request gate — every authenticated
# request now re-confirms the user's pure-DB `allowed` flag (uniform for GitHub
# and local password/OTP accounts). Consequences:
#   - A GitHub login NOT on this list is not granted `allowed` (fail-closed; empty
#     /unset provisions no GitHub user).
#   - Editing this env does NOT revoke a GitHub user already provisioned `allowed`
#     at runtime — revoke by DISABLING the account in the console account-admin
#     page (sets `allowed = false`), the documented revocation path.
#   - Local (password/OTP) accounts are NOT governed by this list at all; they are
#     created `allowed` by an admin and gated solely on the DB `allowed` flag.
AUTH_ALLOWLIST=

# ── Auth: default-admin bootstrap (add-private-account-identity) ───────────────
# On boot the api idempotently seeds a default admin keyed by ADMIN_EMAIL
# (role=admin, allowed=true, mustChangePassword=true) so a fresh, no-GitHub deploy
# is usable. UNSET ADMIN_EMAIL → no admin is seeded (skipped). The seed is self-
# contained + re-runnable; an existing admin is left intact.
ADMIN_EMAIL=
# Optional. When set, the admin is seeded with THIS password (argon2-hashed at
# rest). When UNSET, a strong random password is generated, its hash stored, and
# the PLAINTEXT held in memory for a ONE-TIME reveal via POST /auth/admin/reveal
# (returned exactly once, then cleared; a restart before reveal regenerates). The
# DB never holds the plaintext.
ADMIN_PASSWORD=

# Optional. Turns the email+password login METHOD on/off in the login modal.
# Defaults ON (the default admin always has a password identity). Set to
# false/0/no to hide the password method (capability flag only — not a security
# gate; the endpoint always enforces its own fail-closed checks).
# PASSWORD_AUTH_ENABLED=true

# ── Mail / email-OTP login (add-private-account-identity) ──────────────────────
# SMTP transport for the email verification-code (OTP) login method. ALL FIVE
# must be set for OTP to be advertised AND served — a partial config is treated as
# unconfigured (fail-closed: the OTP method is hidden and OTP requests are
# refused). With SMTP unset, password + GitHub login still work.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# The From address codes are sent as (e.g. "CAP <no-reply@example.com>").
SMTP_FROM=

# ── Auth: pre-auth brute-force throttle (add-private-account-identity) ─────────
# A dedicated rate tier for the PUBLIC pre-authentication endpoints (password
# login, OTP request/verify, change-password), keyed on client IP + submitted
# email (no principal exists pre-auth). Independent of the per-principal API
# throttler. Both are env-tunable and FLOORED so a bad value can never disable the
# limiter (a 0/negative/NaN falls back to the default).
# AUTH_RATE_LIMIT=10
# AUTH_RATE_TTL_SEC=60

# Session cookie signing secret (random, long). Required for OAuth sessions —
# signs the anti-CSRF state cookie and the opaque session. Generate:
#   openssl rand -hex 32
SESSION_SECRET=

# ── Auth: legacy operator token (OPTIONAL — local dev only) ───────────────────
# Break-glass shared-token path, OFF by default. A real OAuth-first deploy does
# NOT need this and should leave it disabled. When AUTH_TOKEN_LEGACY_ENABLED is
# true the api refuses to boot without a non-empty AUTH_TOKEN; when false (or
# unset) both are ignored and the api boots on OAuth config alone. The local-dev
# bring-up generates AUTH_TOKEN and sets AUTH_TOKEN_LEGACY_ENABLED=true for you.
AUTH_TOKEN_LEGACY_ENABLED=false
AUTH_TOKEN=

# ── Codex credentials ────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting compatible-provider API keys at rest.
# 64 hex chars (32 bytes) or base64 of 32 bytes. Generate: openssl rand -hex 32
CODEX_CRED_ENC_KEY=

# ── Public URLs / CORS / cookie scope (the most error-prone settings) ─────────
# Comma-separated origin(s) the web console is served from. The api allow-lists
# these for cross-origin requests AND redirects the browser to the FIRST entry
# after OAuth login. Unset allows NO browser app (same-origin/cURL still work).
#   same-origin (api also serves web):    leave UNSET
#   compose web on its own host/port:     http://localhost:3000
#   cross-subdomain deploy:               https://cap.example.com
WEB_ORIGIN=
# The session cookie's Domain attribute. Leave UNSET for same-origin/same-host
# AND for cross-SITE deploys (web on a *different registrable domain*, e.g.
# *.vercel.app); the cookie stays host-only. Set it to a registrable PARENT
# (leading dot) ONLY for a cross-SUBDOMAIN deploy where web + api are siblings
# (web cap.example.com, api cap-api.example.com):
#   SESSION_COOKIE_DOMAIN=.example.com
SESSION_COOKIE_DOMAIN=

# ── Database ──────────────────────────────────────────────────────────────────
# Connection string for the orchestrator's Prisma layer. Leave UNSET to use the
# compose-internal Postgres (the docker-compose.yml default). Set it to point at
# an EXTERNAL Postgres or to use different credentials.
#   e.g. DATABASE_URL=postgresql://user:pass@db.example.com:5432/cap?schema=public
DATABASE_URL=

# ── Metrics sampler ──────────────────────────────────────────────────────────
METRICS_SAMPLING_ENABLED=true
# METRICS_SAMPLE_CADENCE_MS=5000
# METRICS_SAMPLE_STALE_MS=15000

# ── Logging (structured-logging) ─────────────────────────────────────────────
# pino log level for structured JSON app/HTTP logs to stdout. Default `info`;
# raise to `debug` for an incident (env change + restart, no code change).
# LOG_LEVEL=info

# ── Update checks (update-availability-check) ─────────────────────────────────
# GET /update-status compares the running CAP_VERSION against the latest GitHub
# Release. By DEFAULT the lookup goes through cap's public, cache-only mirror
# (a Cloudflare Worker at https://releases.cap.douglasdong.com) that proxies
# GitHub's releases/latest and serves it from the CF edge cache — converging
# fleet traffic onto one cached upstream and surviving a GitHub API blip within
# the cache window. It is a PURE cache: no token, no telemetry, no payload
# rewrite. To stay fully direct and zero-dependency on any third party, point it
# back at GitHub (this is the supported escape hatch):
#   GITHUB_API_BASE=https://api.github.com
# GITHUB_API_BASE=https://releases.cap.douglasdong.com
#
# The repo whose Releases are checked. Defaults to the cap repo; point it at your
# fork if you cut your own releases. Orthogonal to GITHUB_API_BASE — the mirror
# transparently proxies whatever owner/repo you set.
# GITHUB_RELEASES_REPO=Xeonice/cloud-agent-platform
#
# Cache TTL (ms) for the in-process release lookup; minutes-scale, 60s floor.
# UPDATE_CHECK_CACHE_TTL_MS=300000
