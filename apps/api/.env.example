# apps/api/.env — backend secrets/config for the docker-compose self-host target.
# Copy to apps/api/.env and fill in. NEVER commit the real .env (gitignored).
# Consumed via docker-compose.yml `env_file`.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Legacy operator-token break-glass path (default OFF). When true, an operator
# may authenticate with `Authorization: Bearer <AUTH_TOKEN>` (constant-time).
AUTH_TOKEN_LEGACY_ENABLED=false
AUTH_TOKEN=

# GitHub OAuth App — the primary auth path. The login flow refuses to start
# unless BOTH are set (fail-closed). Callback: <api-origin>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Hard allowlist gate — comma-separated immutable numeric GitHub ids. Only these
# identities may enter the host-root console. Empty/unset denies ALL (fail-closed).
AUTH_ALLOWLIST=

# Session cookie signing secret (random, long). Required for OAuth sessions.
SESSION_SECRET=

# ── Codex credentials ────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting compatible-provider API keys at rest.
# 64 hex chars (32 bytes) or base64 of 32 bytes. Generate: openssl rand -hex 32
CODEX_CRED_ENC_KEY=

# ── CORS / cross-origin web ──────────────────────────────────────────────────
# Comma-separated origins the cross-origin web console is served from (e.g. the
# Vercel URL or http://localhost:3000 for local dev). Unset allows no browser app.
WEB_ORIGIN=

# ── Metrics sampler ──────────────────────────────────────────────────────────
METRICS_SAMPLING_ENABLED=true
# METRICS_SAMPLE_CADENCE_MS=5000
# METRICS_SAMPLE_STALE_MS=15000
