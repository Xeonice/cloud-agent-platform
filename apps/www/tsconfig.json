{
  "extends": "@cap/tsconfig/next.json",
  "compilerOptions": {
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
