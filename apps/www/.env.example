# --- www: build-time public config (design D6) ---
# These are baked into the static export at build time and reach the browser
# bundle (NEXT_PUBLIC_* is Next.js's public-env convention, matching the repo's
# console env). A SINGLE source (lib/site-config.ts) consumes both and feeds:
#   - the SEO/OG metadata helpers (canonical + OG URLs, app/[locale]/layout.tsx),
#   - the hreflang alternates (lib/hreflang.ts),
#   - the Hero `curl | sh` one-liner + footer/GitHub links (the {domain}/{repo}
#     tokens in content/*.ts), and
#   - the build-time install.sh marker injection (scripts/inject-install-sh.mjs).

# Public canonical site origin (scheme + host, no trailing slash),
# e.g. https://example.com — used for canonical/OG/hreflang URLs, the Hero
# `curl https://<domain>/install.sh` command, and the install.sh domain marker.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public Git repository URL the installer clones and the docs/footer link to.
NEXT_PUBLIC_REPO_URL=https://github.com/Xeonice/cloud-agent-platform

# Public API origin (scheme + host, no trailing slash), e.g.
# https://cap-api.example.com — the host where the backend serves the `/mcp`
# endpoint. Fills the {apiDomain} token in the MCP-connect section's endpoint
# URL. This is the API host, DISTINCT from NEXT_PUBLIC_SITE_URL (the marketing
# site host). The value is inlined statically at build time — the site still
# makes no runtime backend call. (Matches the console's VITE_API_BASE_URL local
# convention so both frontends point at the same local api.)
NEXT_PUBLIC_API_URL=http://localhost:8080
