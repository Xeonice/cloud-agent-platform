{
  "name": "@cap/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm build && node --test src/*.test.mjs",
    "test:public-surface": "node --test src/public-v1-operations.test.mjs ../../scripts/public-surface-*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "cron-parser": "^5.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cap/eslint-config": "workspace:*",
    "@cap/tsconfig": "workspace:*",
    "eslint": "^9.27.0",
    "typescript": "^5.5.4"
  }
}
