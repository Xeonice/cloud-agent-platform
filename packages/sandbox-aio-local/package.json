{
  "name": "@cap/sandbox-aio-local",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pure local AIO sandbox provider configuration helpers for CAP.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm --filter @cap/sandbox-core build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @cap/sandbox-core build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node src/aio-local-provider.test.mjs",
    "coverage": "pnpm build && c8 --100 --include=dist/**/*.js --reporter=text node src/aio-local-provider.test.mjs",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@cap/sandbox-core": "workspace:*"
  },
  "devDependencies": {
    "@cap/eslint-config": "workspace:*",
    "@cap/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^9.27.0",
    "typescript": "^5.5.4"
  }
}
