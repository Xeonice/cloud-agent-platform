# Run-package env for docker-compose.prod.yml (source-free, prebuilt images).
# Copy to `.env` NEXT TO docker-compose.prod.yml, fill it in, then run a
# service-scoped prebuilt compose command, for example:
#
#   COMPOSE_PROFILES=web docker compose -f docker-compose.prod.yml pull api postgres web
#   COMPOSE_PROFILES=web docker compose -f docker-compose.prod.yml up -d api postgres web
#
# Linux/AIO: include `aio-sandbox-image` in both commands so the per-task sandbox
# image is present before tasks run. macOS/BoxLite: do not stage `aio-sandbox-image`.
# Full walkthrough: docs/self-hosting.md.

# -- Which release to run -------------------------------------------------------
# Optional. Unset uses the Docker `latest` tag. For reproducible deploys and
# clean update-status semantics, pin a concrete published Release tag:
# CAP_VERSION=v0.24.0
#
# Release images currently default to linux/amd64. Apple Silicon Docker Desktop /
# Colima can run api/web through emulation with this platform pin.
# CAP_IMAGE_PLATFORM=linux/amd64

# -- Local account auth --------------------------------------------------------
# Self-hosted console login uses local accounts. The api idempotently seeds this
# default admin on boot. Set ADMIN_PASSWORD for a fixed initial password; leave it
# unset to let the api generate one and expose it once through /auth/admin/reveal.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
PASSWORD_AUTH_ENABLED=true

# Optional email-code login. If SMTP is absent, OTP is hidden and password login
# still works.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Required secrets. Generate strong random values:
#   openssl rand -hex 32
SESSION_SECRET=
CODEX_CRED_ENC_KEY=

# -- Sandbox provider ----------------------------------------------------------
# quick-deploy auto-selects macOS -> BoxLite and Linux -> AIO. For manual compose,
# choose the matching env below. Explicit CAP_SANDBOX_PROVIDER=boxlite fails closed
# when BOXLITE_* is invalid; auto mode keeps Linux on AIO unless BoxLite is selected.
#
# Linux / AIO:
# CAP_SANDBOX_PROVIDER=aio
#
# macOS / BoxLite:
# CAP_SANDBOX_PROVIDER=boxlite
# BOXLITE_ENDPOINT=http://host.docker.internal:7331
# BOXLITE_READINESS_ENDPOINT=http://127.0.0.1:7331
# BOXLITE_API_TOKEN=
# BOXLITE_IMAGE=cap-boxlite:2026-06-27
# BOXLITE_IMAGE_MAP=codex=cap-boxlite-codex:1,claude-code=cap-boxlite-claude:1
# BOXLITE_PROTOCOL_MODE=native
# BOXLITE_PATH_PREFIX=default
# BOXLITE_PROVIDER_ID=boxlite
# BOXLITE_PROVIDER_PRIORITY=100
# BOXLITE_PROVIDER_LOCATION=local
# BOXLITE_WORKSPACE_PATH=/workspace
# BOXLITE_SANDBOX_ID_PREFIX=cap-boxlite-
# BOXLITE_SANDBOX_MODE=workspace-write
# BOXLITE_CLIENT_MODE=rest
# BOXLITE_TIMEOUT_MS=30000
# BOXLITE_TERMINAL_MODE=pty
# BOXLITE_CAPABILITIES=terminal.websocket,terminal.interactive,command.exec,workspace.git.materialize,workspace.git.deliver,workspace.archive.transfer,lifecycle.readopt,lifecycle.readoption

# -- Public origins / cookie scope --------------------------------------------
# WEB_ORIGIN: web console origin(s) the api CORS-allowlists and redirects to.
# SESSION_COOKIE_DOMAIN: registrable parent (e.g. .example.com) for
# cross-subdomain deploys; leave unset for same-origin and cross-site deploys.
WEB_ORIGIN=
SESSION_COOKIE_DOMAIN=
#
# Same-host release-image discovery. quick-deploy writes these automatically.
# With web at http://<host>:3000 and api at http://<host>:8080 (or a custom
# API_HOST_PORT), the browser derives the api/ws endpoints from the hostname it
# actually opened instead of using a localhost bundle.
# CAP_PUBLIC_API_PORT=8080
# CAP_SERVER_API_BASE_URL=http://api:8080
# WEB_ORIGIN_AUTO_SAME_HOST=true
# WEB_ORIGIN_AUTO_SAME_HOST_PORT=3000
#
# For a fully custom split-domain deploy, set explicit browser-facing endpoints
# instead of relying on same-host discovery:
# CAP_PUBLIC_API_BASE_URL=https://cap-api.example.com
# CAP_PUBLIC_WS_URL=wss://cap-api.example.com

# -- Optional database / ports -------------------------------------------------
# External Postgres (else the built-in postgres service is used):
# DATABASE_URL=postgresql://user:pass@host:5432/cap?schema=public
# Or override the built-in Postgres credentials:
# POSTGRES_USER=cap
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=cap
#
# User-facing api/web bind all host interfaces by default. Set *_HOST_BIND to
# 127.0.0.1 for loopback-only. Public DNS/TLS/proxy/firewall setup remains
# operator-managed.
# API_HOST_BIND=0.0.0.0
# API_HOST_PORT=8080
# WEB_HOST_BIND=0.0.0.0
# WEB_HOST_PORT=3000
#
# Concurrency ceiling for running tasks:
# MAX_CONCURRENT_TASKS=5

# -- Claude Code runtime auth --------------------------------------------------
# Optional. Long-lived Claude Code OAuth token authorizing `claude-code` tasks.
# Mint it on a workstation where you are signed into Claude:
#   claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=

# -- Opt-in observability (loki + alloy + grafana) -----------------------------
#   observability         -> loki + grafana-alloy (collect + 14-day store)
#   observability,grafana -> + grafana UI (loopback 127.0.0.1:3001)
# COMPOSE_PROFILES=observability,grafana
#
# Grafana (only when the `grafana` profile is on):
# GRAFANA_PG_USER=grafana_ro
# GRAFANA_PG_PASSWORD=
# GRAFANA_ADMIN_PASSWORD=
# GRAFANA_ROOT_URL=https://grafana.example.com

# -- Legacy break-glass token --------------------------------------------------
# Normal local-account self-hosts do not need this. quick-deploy enables it for
# its localhost/trial path and prints the token.
# AUTH_TOKEN_LEGACY_ENABLED=false
# AUTH_TOKEN=
