# Run-package env for docker-compose.prod.yml (source-free, prebuilt images).
# Copy to `.env` NEXT TO docker-compose.prod.yml, fill it in, then:
#   docker compose -f docker-compose.prod.yml pull
#   docker compose -f docker-compose.prod.yml up -d
# Full walkthrough (GitHub OAuth app, allowlist, domains/cookie scope): docs/self-hosting.md.

# ── Which release to run (OPTIONAL — defaults to `latest`) ───────────────────
# Unset → runs `latest` (the newest published Release), so a bare
# `docker compose -f docker-compose.prod.yml up -d` just runs the latest release.
# PIN a specific tag for a reproducible / rollback-able deploy; updating a pinned
# deploy = bump this + re-pull/up. Pins api + web + aio-sandbox to ONE matched set.
# CAP_VERSION=v0.1.0

# ── GitHub OAuth app (REQUIRED — login is fail-closed without these) ─────────
# Create at https://github.com/settings/developers ; callback = <api-origin>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional: only set to override the app's registered callback (unusual proxies).
GITHUB_OAUTH_REDIRECT_URI=

# ── Operator allowlist (REQUIRED — empty/unset denies ALL access) ────────────
# Comma-separated NUMERIC GitHub user ids (never logins). `gh api user --jq .id`.
AUTH_ALLOWLIST=

# ── Secrets (REQUIRED — generate strong random values) ───────────────────────
# SESSION_SECRET: long random string.  CODEX_CRED_ENC_KEY: 64 hex chars (AES-256).
#   openssl rand -hex 32   /   openssl rand -hex 32
SESSION_SECRET=
CODEX_CRED_ENC_KEY=

# ── Claude Code runtime auth (OPTIONAL — only for `claude-code` tasks) ───────
# Long-lived Claude Code OAuth token authorizing a `claude-code` task's `claude`
# CLI inside the sandbox (injected as the launch-env CLAUDE_CODE_OAUTH_TOKEN; no
# auth file is written). UNSET → the Claude runtime reports not-ready, the create
# dialog disables it, and a `claude-code` create fails closed — the codex path is
# unaffected, so leaving this empty is fine if you only run codex tasks.
#
# Mint it on a WORKSTATION (never in-sandbox) where you are signed into Claude:
#   claude setup-token
# Paste the printed token below. Tokens are long-lived (~1yr) with NO auto-refresh;
# re-mint with the same command when tasks start failing with an auth error. One
# token pools the account's rate limit across all sandboxes AND claude.ai.
# CLAUDE_CODE_OAUTH_TOKEN=

# ── Public origins / cookie scope (REQUIRED for a real cross-origin deploy) ──
# WEB_ORIGIN: the web console origin the api CORS-allowlists + redirects to.
# SESSION_COOKIE_DOMAIN: registrable parent (e.g. .example.com) for cross-subdomain;
#   leave UNSET for cross-site (web on a different registrable domain). See docs/self-hosting.md.
WEB_ORIGIN=
SESSION_COOKIE_DOMAIN=

# ── Optional ─────────────────────────────────────────────────────────────────
# External Postgres (else the built-in postgres service is used):
# DATABASE_URL=postgresql://user:pass@host:5432/cap?schema=public
# Or override the built-in Postgres credentials:
# POSTGRES_USER=cap
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=cap
# Concurrency ceiling for running tasks:
# MAX_CONCURRENT_TASKS=5
# Host port for the in-compose web console (with COMPOSE_PROFILES=web):
# WEB_HOST_PORT=3000

# ── Opt-in observability (loki + alloy + grafana) ────────────────────────────
# Self-select on startup; UNSET = none start (api still logs to stdout). Persisting
# this in .env keeps it on across `up --remove-orphans` (ad-hoc --profile flags drop).
#   observability         → loki + grafana-alloy (collect + 14-day store)
#   observability,grafana → + grafana UI (loopback 127.0.0.1:3001, front with your tunnel)
# COMPOSE_PROFILES=observability,grafana
#
# Grafana (only when the `grafana` profile is on):
# - The Loki log dashboards work out-of-box once enabled.
# - The Postgres-Audit panel needs a ONE-TIME manual step: run
#     psql -U cap -d cap -f deploy/observability/grafana-ro-role.sql   (edit CHANGE_ME first)
#   to create the read-only `grafana_ro` role, then set the two vars below to match.
# - Set GRAFANA_ADMIN_PASSWORD before exposing Grafana (image ships admin/admin).
# GRAFANA_PG_USER=grafana_ro
# GRAFANA_PG_PASSWORD=
# GRAFANA_ADMIN_PASSWORD=
# GRAFANA_ROOT_URL=https://grafana.example.com

# ── Legacy break-glass token (dev only; leave disabled for OAuth-first prod) ─
# AUTH_TOKEN_LEGACY_ENABLED=false
# AUTH_TOKEN=
